.board-node {
    position: absolute;
    min-width: 140px;
    max-width: 280px;
    background: #fff;
    border: 1px solid #c3dafe;
    border-radius: 8px;
    box-shadow: 0 4px 12px rgba(33, 56, 104, 0.08);
    padding: 8px 12px;
    user-select: none;
    cursor: move;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
}

.board-node:hover {
    box-shadow: 0 6px 16px rgba(33, 56, 104, 0.12);
    border-color: #3b82f6;
}

.board-node.selected {
    border-color: #3b82f6;
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
}

.board-node h4 {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: #1e293b;
    line-height: 1.4;
}

.board-node p {
    margin: 4px 0 0;
    color: #64748b;
    font-size: 0.75rem;
}

.board-node .node-add-child {
    position: absolute;
    right: -10px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    background: #3b82f6;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease;
    border: none;
    padding: 0;
}

.board-node:hover .node-add-child {
    opacity: 1;
}

.board-edge-path {
    fill: none;
    stroke: #94a3b8;
    stroke-width: 1.5;
    transition: stroke 0.2s ease, stroke-width 0.2s ease;
}

.board-edge-path:hover {
    stroke: #3b82f6;
    stroke-width: 2.5;
}
