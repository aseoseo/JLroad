@page "/library"
@layout WorkspaceLayout
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using JIroad.Api
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Библиотека шаблонов | JIroad</PageTitle>

<div class="container-fluid px-2 px-md-4 my-4" style="max-width: 1200px; font-family: system-ui, sans-serif;">
    
    <header class="p-4 mb-4 bg-white border rounded-3 shadow-sm border-light-subtle">
        <h1 class="m-0 text-dark fw-bold fs-4">📚 Глобальная библиотека шаблонов</h1>
        <p class="m-0 text-muted mt-1 small" style="font-size: 0.95rem;">Изучайте и заимствуйте лучшие учебные траектории сообщества JIroad</p>
    </header>

    @if (_isLoading)
    {
        <div class="d-flex flex-column justify-content-center align-items-center" style="height: 250px; gap: 1rem;">
            <div class="spinner-border text-primary" role="status"></div>
            <span class="text-muted small">Загрузка общедоступных треков...</span>
        </div>
    }
    else if (_templates.Count == 0)
    {
        <div class="text-center p-5 bg-white border border-light-subtle rounded-4 shadow-sm">
            <div class="display-4 mb-3">📦</div>
            <h3 class="h6 text-dark fw-bold mb-2">В библиотеке пока пусто</h3>
            <p class="text-muted small mx-auto" style="max-width: 450px;">Будьте первыми! Опубликуйте свою дорожную карту из её верхнего меню редактора холста, чтобы поделиться ей со всеми.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var tm in _templates)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 bg-white border border-light-subtle rounded-3 p-4 d-flex flex-column justify-content-between shadow-sm" style="transition: transform 0.2s;">
                        <div>
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <h3 class="h6 m-0 text-dark fw-bold text-truncate" style="max-width: 75%;" title="@tm.Title">@tm.Title</h3>
                                <span class="badge bg-light text-secondary border small py-1 px-2" style="font-size: 0.75rem;">@tm.Difficulty</span>
                            </div>
                            <p class="text-secondary small mb-4 lh-base" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; height: 4rem;">@tm.Description</p>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-3 border-top border-light-subtle">
                            <span class="text-secondary small fw-medium">🧩 Этапов: <b class="text-dark">@tm.NodesCount</b></span>
                            <button class="btn btn-sm btn-primary text-white fw-bold px-3 py-2 rounded-3 border-0"
                                    @onclick="() => CloneTemplate(tm.Id)">
                                📥 Забрать карту
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<RoadmapResponse> _templates = new();
    private bool _isLoading = true;
    private string _token = "";

    protected override async Task OnInitializedAsync()
    {
        _token = await Js.InvokeAsync<string>("jiroad.loadToken");
        if (string.IsNullOrWhiteSpace(_token))
        {
            Nav.NavigateTo("/auth/login", true);
            return;
        }
        await LoadTemplates();
    }

    private HttpClient Client()
    {
        // ИСПРАВЛЕНО: Умное переключение BaseAddress при запуске внутри Docker-контейнера
        string baseAddress = Nav.BaseUri;
        if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
        {
            baseAddress = "http://127.0.0.1:8080/";
        }

        var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
        http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", _token);
        return http;
    }

    private async Task LoadTemplates()
    {
        _isLoading = true;
        try
        {
            using var http = Client();
            // Загрузка публичных шаблонов
            _templates = await http.GetFromJsonAsync<List<RoadmapResponse>>("/api/roadmap/templates/public") ?? new();
        }
        catch (Exception ex) 
        { 
            Console.WriteLine($"Ошибка загрузки шаблонов: {ex.Message}");
        }
        finally 
        { 
            _isLoading = false; 
            StateHasChanged();
        }
    }

    private async Task CloneTemplate(int templateId)
    {
        try
        {
            using var http = Client();
            
            // Сохранено: Путь соответствует Program.cs
            var response = await http.PostAsync($"/api/roadmap/templates/{templateId}/clone", null);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<CloneResult>();
                if (result != null)
                {
                    await Js.InvokeVoidAsync("alert", "Шаблон успешно скопирован в ваш аккаунт!");
                    Nav.NavigateTo($"/canvas/{result.NewRoadmapId}");
                }
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[Ошибка клонирования]: {response.StatusCode} - {errorMsg}");
                await Js.InvokeVoidAsync("alert", $"Не удалось забрать карту. Сервер вернул код: {response.StatusCode}");
            }
        }
        catch (Exception ex) 
        { 
            Console.WriteLine($"[КРИТИЧЕСКАЯ ОШИБКА КЛОНИРОВАНИЯ] {ex.Message}");
            await Js.InvokeVoidAsync("alert", "Произошла сетевая ошибка при попытке скопировать шаблон.");
        }
    }

    private class CloneResult
    {
        public int NewRoadmapId { get; set; }
    }
}