    private void OnCanvasPointerDown(PointerEventArgs e)
    {
        if (tool == ToolMode.Pan || draggingNodeId == 0)
        {
            panning = true;
            startPanX = e.ClientX;
            startPanY = e.ClientY;
            selectedEdgeId = 0; 
            selectedNodeIds.Clear();
        }
    }

    private void OnNodePointerDown(int id, PointerEventArgs e)
    {
        if (tool == ToolMode.Pan || tool == ToolMode.Connect || _isDrawingEdge) return;
        if (isReadOnly) return; 

        _wasDragged = false; 
        draggingNodeId = id;
        var node = nodes.FirstOrDefault(x => x.Id == id);
        if (node != null)
        {
            SaveHistoryState();
            nodeStartX = node.X;
            nodeStartY = node.Y;
        }
        pointerStartX = e.ClientX;
        pointerStartY = e.ClientY;
    }

    private async Task OnCanvasPointerMove(PointerEventArgs e)
    {
        if (draggingNodeId != 0 && tool != ToolMode.Pan && !isReadOnly)
        {
            var node = nodes.FirstOrDefault(x => x.Id == draggingNodeId);
            if (node is null) return;

            double dx = e.ClientX - pointerStartX;
            double dy = e.ClientY - pointerStartY;
            if (Math.Abs(dx) > 5 || Math.Abs(dy) > 5) _wasDragged = true;

            node.X = nodeStartX + dx / zoom;
            node.Y = nodeStartY + dy / zoom;
            StateHasChanged();
            return;
        }

        if (_isDrawingEdge && !isReadOnly)
        {
            var rect = await Js.InvokeAsync<BoundingRect>("jiroad.getCanvasBoundingRect", "#main-board-canvas");
            _currentMouseX = (e.ClientX - rect.Left - offsetX) / zoom;
            _currentMouseY = (e.ClientY - rect.Top - offsetY) / zoom;
            StateHasChanged();
            return;
        }

        if (!panning) return;
        offsetX += e.ClientX - startPanX;
        offsetY += e.ClientY - startPanY;
        startPanX = e.ClientX;
        startPanY = e.ClientY;
        StateHasChanged();
    }

    private async Task PublishToLibrary()
    {
        if (isReadOnly) return;
        try
        {
            using var http = Client();
            var response = await http.PostAsync($"/api/roadmap/{RoadmapId}/publish", null);
            if (response.IsSuccessStatusCode)
            {
                await Js.InvokeVoidAsync("alert", "Поздравляем! Ваша дорожная карта успешно опубликована и теперь доступна всем пользователям в глобальной Библиотеке шаблонов.");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[ОШИБКА ПУБЛИКАЦИИ] {error}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ОШИБКА HTTP] {ex.Message}");
        }
    }
    
    private async Task OnCanvasPointerUp(PointerEventArgs e)
    {
        panning = false;
        if (draggingNodeId != 0 && !isReadOnly)
        {
            var node = nodes.FirstOrDefault(x => x.Id == draggingNodeId);
            if (node != null) await UpdateNode(node);
        }
        draggingNodeId = 0;
        await Task.Delay(50);
        _isDrawingEdge = false;
        _edgeSourceNode = null;
        StateHasChanged();
    }

    private async Task ConnectEdge(NodeVm targetNode)
    {
        if (isReadOnly) return;
        if (_isDrawingEdge && _edgeSourceNode != null && _edgeSourceNode.Id != targetNode.Id)
        {
            if (!edges.Any(e => e.FromNodeId == _edgeSourceNode.Id && e.ToNodeId == targetNode.Id))
            {
                await CreateEdge(_edgeSourceNode.Id, targetNode.Id, edgeType);
            }
        }
        if (!_isDrawingEdge && draggingNodeId == targetNode.Id) await UpdateNode(targetNode);
        draggingNodeId = 0;
    }
    
    private void OnWheel(WheelEventArgs e)
    {
        var delta = e.DeltaY < 0 ? 0.07 : -0.07;
        zoom = Math.Clamp(zoom + delta, 0.25, 2.5);
    }

    private void ResetView()
    {
        zoom = 1;
        offsetX = 0; offsetY = 0;
    }

    private async Task AutoLayout()
    {
        if (isReadOnly) return;
        SaveHistoryState();
        for (var i = 0; i < nodes.Count; i++)
        {
            nodes[i].X = 120 + (i % 5) * 250;
            nodes[i].Y = 120 + (i / 5) * 160;
        }
        var saveTasks = nodes.Select(node => UpdateNode(node));
        await Task.WhenAll(saveTasks);
        StateHasChanged();
    }

    private string Path(NodeVm from, NodeVm to, EdgeVm edge)
    {
        const double nodeW = 220;
        const double nodeH = 92;  
        var sharedEdges = edges.Where(e => (e.FromNodeId == from.Id && e.ToNodeId == to.Id) || (e.FromNodeId == to.Id && e.ToNodeId == from.Id)).OrderBy(e => e.Id).ToList();
        int edgeIndex = sharedEdges.IndexOf(edge);
        double offset = sharedEdges.Count > 1 ? (edgeIndex - (sharedEdges.Count / 2)) * 18 : 0;
        bool isForward = (to.X - from.X) > 60;
        bool verticalDeviated = Math.Abs(to.Y - from.Y) > 80;
        if (isForward && !verticalDeviated)
        {
            double startX = from.X + nodeW;
            double startY = from.Y + (nodeH / 2) + offset;
            double endX = to.X;
            double endY = to.Y + (nodeH / 2) + offset;
            double controlOffset = Math.Max(60, Math.Abs(endX - startX) * 0.5);
            return $"M {startX.ToString(CultureInfo.InvariantCulture)} {startY.ToString(CultureInfo.InvariantCulture)} C {(startX + controlOffset).ToString(CultureInfo.InvariantCulture)} {startY.ToString(CultureInfo.InvariantCulture)}, {(endX - controlOffset).ToString(CultureInfo.InvariantCulture)} {endY.ToString(CultureInfo.InvariantCulture)}, {endX.ToString(CultureInfo.InvariantCulture)} {endY.ToString(CultureInfo.InvariantCulture)}";
        }
        else
        {
            double startX = from.X + (nodeW / 2) + offset;
            double startY = from.Y + nodeH; 
            double endX = to.X + (nodeW / 2) + offset; double endY = to.Y;
            double drop = Math.Max(80, Math.Abs(from.X - to.X) * 0.4) + (edgeIndex * 15);
            if (from.Y > to.Y) { startY = from.Y; endY = to.Y + nodeH; drop = -drop; }
            return $"M {startX.ToString(CultureInfo.InvariantCulture)} {startY.ToString(CultureInfo.InvariantCulture)} C {startX.ToString(CultureInfo.InvariantCulture)} {(startY + drop).ToString(CultureInfo.InvariantCulture)}, {endX.ToString(CultureInfo.InvariantCulture)} {(endY - drop).ToString(CultureInfo.InvariantCulture)}, {endX.ToString(CultureInfo.InvariantCulture)} {endY.ToString(CultureInfo.InvariantCulture)}";
        }
    }

    private async Task StartDrawingEdge(PointerEventArgs e, NodeVm sourceNode)
    {
        if (isReadOnly) return;
        _isDrawingEdge = true;
        _edgeSourceNode = sourceNode;
        var rect = await Js.InvokeAsync<BoundingRect>("jiroad.getCanvasBoundingRect", "#main-board-canvas");
        _currentMouseX = (e.ClientX - rect.Left - offsetX) / zoom;
        _currentMouseY = (e.ClientY - rect.Top - offsetY) / zoom;
    }

    private async Task UpdateSelectedNode(NodeVm selected)
    {
        if (!isReadOnly)
        {
            SaveHistoryState();
            if (selected.Progress == 0) selected.Status = "Planned";
            else if (selected.Progress == 100) selected.Status = "Completed";
            else selected.Status = "In Progress";
        }
        await UpdateNode(selected);
        StateHasChanged();
    }

    private async Task DeleteCurrentRoadmap()
    {
        if (isReadOnly) return;
        bool confirmed = await Js.InvokeAsync<bool>("confirm", "Вы абсолютно уверены, что хотите безвозвратно удалить эту дорожную карту? Вы выйдете из редактора, а все данные на холсте будут стерты.");
        if (!confirmed) return;

        try
        {
            using var http = Client();
            var response = await http.DeleteAsync($"/api/roadmap/{RoadmapId}");
            if (response.IsSuccessStatusCode)
            {
                Nav.NavigateTo("/dashboard");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[Canvas Delete Error]: {error}");
                await Js.InvokeVoidAsync("alert", "Произошла ошибка при попытке удаления карты.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Canvas Http Error]: {ex.Message}");
        }
    }

    private async Task SaveEntireRoadmapExplicitly()
    {
        if (_isSavingNow) return;
        _isSavingNow = true; _justSavedAlert = false;
        StateHasChanged();
        try
        {
            var saveTasks = nodes.Select(node => UpdateNode(node));
            await Task.WhenAll(saveTasks);
            _justSavedAlert = true;
        }
        catch (Exception ex) { Console.WriteLine($"[ОШИБКА] {ex.Message}"); }
        finally
        {
            _isSavingNow = false;
            StateHasChanged();
            _ = Task.Delay(3000).ContinueWith(_ => { _justSavedAlert = false; InvokeAsync(StateHasChanged); });
        }
    }

    private string CalculatePreviewBezier(NodeVm from, double targetX, double targetY)
    {
        double startX = from.X + 220;
        double startY = from.Y + 46;  
        double controlOffset = Math.Max(60, Math.Abs(targetX - startX) * 0.5);
        return $"M {startX.ToString(CultureInfo.InvariantCulture)} {startY.ToString(CultureInfo.InvariantCulture)} C {(startX + controlOffset).ToString(CultureInfo.InvariantCulture)} {startY.ToString(CultureInfo.InvariantCulture)}, {(targetX - controlOffset).ToString(CultureInfo.InvariantCulture)} {targetY.ToString(CultureInfo.InvariantCulture)}, {targetX.ToString(CultureInfo.InvariantCulture)} {targetY.ToString(CultureInfo.InvariantCulture)}";
    }

    private void NavigateToNode(int nodeId)
    {
        if (_wasDragged || _isDrawingEdge) return;
        if (tool == ToolMode.Connect && !isReadOnly)
        {
            if (pendingSourceNodeId == 0) pendingSourceNodeId = nodeId;
            else if (pendingSourceNodeId != nodeId)
            {
                var targetNode = nodes.FirstOrDefault(n => n.Id == nodeId);
                if (targetNode != null) _ = CreateEdge(pendingSourceNodeId, targetNode.Id, edgeType);
                pendingSourceNodeId = 0;
            }
            return;
        }
        if (tool == ToolMode.Select || tool == ToolMode.Pan)
        {
            selectedEdgeId = 0;
            if (selectedNodeIds.Contains(nodeId)) selectedNodeIds.Remove(nodeId);
            else { selectedNodeIds.Clear(); selectedNodeIds.Add(nodeId); }
            Nav.NavigateTo($"/node/{nodeId}?RoadmapId={RoadmapId}");
        }
    }

    private string GetStatusText(string status) => status switch { "Planned" => "Не начато", "In Progress" => "В процессе", "Completed" => "Завершено", _ => status };
    private static string EdgeClass(EdgeVm edge) => edge.EdgeType switch { "Альтернативный путь" => "edge-alt", "Параллельный путь" => "edge-parallel", "Ссылка" => "edge-ref", _ => "edge-main" };
    private static string NormalizeNodeType(string value) => value switch { "Тема" => "Topic", "Навык" => "Skill", "Проект" => "Project", "Тест" => "Test", "Контрольная точка" => "Milestone", _ => value };
    
    private async Task UpdateNode(NodeVm node)
    {
        try
        {
            using var http = Client();
            var payload = new { RoadmapId = RoadmapId, Title = node.Title, Description = node.Description, Resource = "", Type = NormalizeNodeType(node.Type), Difficulty = node.Difficulty, Status = node.Status, Progress = node.Progress, Tags = node.Tags, PositionX = Math.Round(node.X, 2), PositionY = Math.Round(node.Y, 2) };
            var response = await http.PutAsJsonAsync($"/api/roadmap/nodes/{node.Id}", payload);
            if (!response.IsSuccessStatusCode)
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[БЭКЕНД ОШИБКА] {response.StatusCode}: {errorContent}");
            }
        }
        catch (Exception ex) { Console.WriteLine($"[ОШИБКА HTTP] {ex.Message}"); }
    }

