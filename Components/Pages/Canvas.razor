@page "/canvas/{RoadmapId:int}"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Globalization
@using System.Text
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@using JIroad.Api
@using System.Text.Json
@implements IDisposable
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Редактор Roadmap | JIroad</PageTitle>

<div class="roadmap-editor-full">
    <aside class="board-rail">
        <button class="rail-btn rail-exit-btn" title="Выйти в главное меню" @onclick="GoToDashboard">🏠</button>
        <div style="width: 100%; height: 1px; background: #e2e8f0; margin: 0.5rem 0;"></div>

        <button class="rail-btn" title="Отменить действие (Ctrl+Z)" @onclick="Undo" disabled="@(!_undoStack.Any() || isReadOnly)" style="opacity: @(_undoStack.Any() && !isReadOnly ? "1" : "0.4")">↩</button>
        <button class="rail-btn" title="Вернуть действие (Ctrl+Y)" @onclick="Redo" disabled="@(!_redoStack.Any() || isReadOnly)" style="opacity: @(_redoStack.Any() && !isReadOnly ? "1" : "0.4")">↪</button>
        <div style="width: 100%; height: 1px; background: #e2e8f0; margin: 0.5rem 0;"></div>

        <button class="rail-btn @(tool == ToolMode.Select ? "active" : "")" title="Выбор и перемещение" @onclick="@(() => SetTool(ToolMode.Select))">⌖</button>
        <button class="rail-btn @(tool == ToolMode.Pan ? "active" : "")" title="Перемещение холста" @onclick="@(() => SetTool(ToolMode.Pan))">✥</button>
        <button class="rail-btn @(tool == ToolMode.Connect ? "active" : "")" title="Управление связями" @onclick="@(() => SetTool(ToolMode.Connect))" disabled="@isReadOnly" style="opacity: @(isReadOnly ? "0.4" : "1")">↝</button>
        <button class="rail-btn" title="Добавить узел" @onclick="CreateNodeQuick" disabled="@isReadOnly" style="opacity: @(isReadOnly ? "0.4" : "1")">＋</button>
        <button class="rail-btn" title="Экспорт карты" @onclick="OpenExportModal">⇩</button>
    </aside>

    <header class="board-top board-top-wide">
        <div class="board-title">Редактор roadmap #@RoadmapId</div>
        <div class="board-actions">
            <button class="ghost" @onclick="NavigateToTests" style="display: inline-flex; align-items: center; gap: 0.25rem; font-weight: 600; color: #0284c7; border-color: rgba(2, 132, 199, 0.4);">
                📝 Тесты карты
            </button>
            
            @if (!isReadOnly)
            {
                <button class="ghost" @onclick="DeleteCurrentRoadmap" style="color: #ef4444; border-color: rgba(239, 68, 68, 0.4); font-weight: 600;">
                    🗑 Удалить роадмап
                </button>

                <button class="ghost" @onclick="PublishToLibrary" style="color: #22c55e; border-color: rgba(34, 197, 94, 0.4); font-weight: 600;">
                    📢 Опубликовать в общие шаблоны
                </button>

                <button class="ghost" @onclick="AutoLayout">Автораскладка</button>
            }
            else
            {
                <div style="background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; padding: 0.35rem 0.75rem; border-radius: 8px; font-size: 0.8rem; font-weight: 600; display: inline-flex; align-items: center;">
                    🔒 Режим чтения структуры
                </div>
            }

            <button class="ghost" @onclick="ResetView">Сброс вида</button>
            <button class="ghost" @onclick="NavigateToAnalytics" style="display: inline-flex; align-items: center; gap: 0.25rem; font-weight: 600; color: #4f46e5;">
                📊 Аналитика прогресса
            </button>
            
            @if (!isReadOnly)
            {
                <button class="cta" @onclick="CreateNodeQuick">+ Узел</button>
            }
        </div>
    </header>

    <section id="main-board-canvas" class="board-canvas" 
             style="position: absolute; inset: 0; top: 60px; bottom: 0; overflow: hidden; cursor: @(panning ? "grabbing" : _isDrawingEdge ? "crosshair" : "default");"
             @onwheel="OnWheel" 
             @onpointerdown="OnCanvasPointerDown" 
             @onpointermove="OnCanvasPointerMove" 
             @onpointerup="OnCanvasPointerUp" 
             @onpointerleave="OnCanvasPointerUp">
        
        <div class="board-grid" style="@TransformStyle"></div>
    
        <div class="board-infinite-surface" style="position: absolute; inset: 0; pointer-events: none; transform-origin: 0 0; @TransformStyle">
            
            <svg class="board-edges" style="position: absolute; width: 10000px; height: 10000px; top: 0; left: 0; overflow: visible; z-index: 2; pointer-events: auto;">
                <defs>
                    <marker id="edgeArrow" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
                        <polygon points="0 0, 8 4, 0 8" fill="#6078a8"/>
                    </marker>
                </defs>
                @foreach (var edge in edges)
                {
                    var from = nodes.FirstOrDefault(x => x.Id == edge.FromNodeId);
                    var to = nodes.FirstOrDefault(x => x.Id == edge.ToNodeId);
                    if (from is null || to is null) continue;
                    
                    <path d="@Path(from, to, edge)" 
                          class="board-edge-path @EdgeClass(edge) @((_hoveredEdgeId == edge.Id || selectedEdgeId == edge.Id) ? "selected-edge" : "")" 
                          stroke="@edge.Color" 
                          stroke-width="@Math.Max(2, edge.Thickness)" 
                          fill="none" 
                          style="pointer-events: stroke;"
                          marker-end="url(#edgeArrow)" />
                }

                @if (_isDrawingEdge && _edgeSourceNode != null)
                {
                    <path d="@CalculatePreviewBezier(_edgeSourceNode, _currentMouseX, _currentMouseY)" 
                          stroke="#3b82f6" stroke-width="2.5" stroke-dasharray="6 4" fill="none" marker-end="url(#edgeArrow)" />
                }
            </svg>

            <div class="board-infinite-surface" style="position: absolute; inset: 0; pointer-events: none; z-index: 2;">
                @foreach (var node in nodes)
                {
                    <article class="board-node @(selectedNodeIds.Contains(node.Id) ? "selected" : "") @(node.Status == "Completed" ? "completed" : "")"
                             style="@($"position: absolute !important; display: block !important; left:{node.X.ToString(CultureInfo.InvariantCulture)}px; top:{node.Y.ToString(CultureInfo.InvariantCulture)}px; {(pendingSourceNodeId == node.Id ? "outline: 4px dashed #3b82f6; outline-offset: 4px;" : "")} pointer-events: auto;")"
                             @onpointerdown="@(e => OnNodePointerDown(node.Id, e))"
                             @onpointerup="@(() => ConnectEdge(node))"
                             @onclick="@(() => NavigateToNode(node.Id))"
                             @onclick:stopPropagation>
                        
                        <div class="node-internal-content" style="@(_isDrawingEdge ? "pointer-events: none;" : "")">
                            <h4>@node.Title</h4>
                            <p>@node.Type · @node.Difficulty</p>
                            <div style="width:100%; background:#e2e8f0; height:6px; border-radius:4px; margin-top:8px; overflow:hidden;">
                                <div style="width:@node.Progress%; background:@(node.Progress == 100 ? "#22c55e" : "#3b82f6"); height:100%; transition:width 0.3s;"></div>
                            </div>
                            <div style="display:flex; justify-content:space-between; margin-top:4px; font-size: 0.75rem; color: #64748b;">
                                <span>@GetStatusText(node.Status)</span>
                                <span>@node.Progress%</span>
                            </div>
                        </div>

                        @if (!isReadOnly)
                        {
                            <div class="node-magnet-handle" 
                                 @onpointerdown="@(e => StartDrawingEdge(e, node))"
                                 @onpointerdown:stopPropagation
                                 title="Вытянуть связь">
                                ＋
                            </div>
                        }
                    </article>
                }
            </div>
            
        </div>

        <button class="canvas-floating-save-btn @(_isSavingNow ? "saving" : "")" 
                @onclick="SaveEntireRoadmapExplicitly" 
                title="Сохранить изменения расположения узлов">
            @if (_isSavingNow)
            {
                <span class="save-spinner"></span>
                <span>Сохранение...</span>
            }
            else if (_justSavedAlert)
            {
                <span>✓ Успешно сохранено в БД!</span>
            }
            else
            {
                <span>💾 Сохранить прогресс</span>
            }
        </button>
    </section>
    
    <aside class="board-panel jiroad-scrollable-panel">
        <h3>Панель</h3>
        <div style="margin-bottom: 1rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem;">
            <p class="fine">Инструмент: <strong>@ToolName(tool)</strong></p>
        </div>

        @if (tool == ToolMode.Connect && !isReadOnly)
        {
            <div class="editor" style="margin-bottom: 1.5rem;">
                <p><strong>Создание связи кликом</strong></p>
                <label style="font-size: 0.8rem; font-weight: bold;">Тип новой связи:</label>
                <select @bind="edgeType" style="margin-bottom: 1rem; width: 100%;">
                    <option>Зависимость</option>
                    <option>Альтернативный путь</option>
                    <option>Параллельный путь</option>
                    <option>Ссылка</option>
                </select>
                
                @if (pendingSourceNodeId == 0)
                {
                    <div style="padding: 10px; background: #eff6ff; border-radius: 6px; color: #1e3a8a; font-size: 0.85rem;">
                        <span style="font-size: 1.2rem;">👆</span> <b>Шаг 1:</b> Кликните по узлу, ОТ которого пойдет стрелка.
                    </div>
                }
                else
                {
                    <div style="padding: 10px; background: #f0fdf4; border-radius: 6px; color: #166534; font-size: 0.85rem;">
                        <span style="font-size: 1.2rem;">🎯</span> <b>Шаг 2:</b> Теперь Кликните по узлу, К которому привязываем.
                    </div>
                    <button type="button" class="ghost" style="margin-top: 0.5rem; width: 100%;" @onclick="@(() => pendingSourceNodeId = 0)">Отменить выбор</button>
                }
            </div>
            
            <div class="editor" style="border-top: 2px dashed #cbd5e1; padding-top: 1rem; flex: 1; display: flex; flex-direction: column; overflow: hidden;">
                <p><strong>🔗 Список всех связей карты:</strong></p>
                @if (edges.Count == 0)
                {
                    <p style="font-size: 0.85rem; font-style: italic; color: #64748b;">На этой карте пока нет связей.</p>
                }
                else
                {
                    <div style="display: flex; flex-direction: column; gap: 0.5rem; max-height: 350px; overflow-y: auto; padding-right: 4px;">
                        @foreach (var edge in edges)
                        {
                            var fromName = nodes.FirstOrDefault(n => n.Id == edge.FromNodeId)?.Title ?? $"Узел {edge.FromNodeId}";
                            var toName = nodes.FirstOrDefault(n => n.Id == edge.ToNodeId)?.Title ?? $"Узел {edge.ToNodeId}";
                            
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; font-size: 0.8rem; transition: background 0.2s;"
                                 @onmouseenter="@(() => _hoveredEdgeId = edge.Id)"
                                 @onmouseleave="@(() => _hoveredEdgeId = 0)">
                                <div style="flex: 1; padding-right: 0.5rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@fromName ➔ @toName (@edge.EdgeType)">
                                    <b>@fromName</b> ➔ <b>@toName</b>
                                    <div style="font-size: 0.75rem; color: #64748b;">@edge.EdgeType</div>
                                </div>
                                <button type="button" style="background: #fee2e2; color: #b91c1c; border: 1px solid #fca5a5; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem; cursor: pointer;"
                                        @onclick="@(() => DeleteSpecificEdgeFromList(edge.Id))">
                                    🗑
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (tool == ToolMode.Select || tool == ToolMode.Pan)
        {
            @if (selectedNodeIds.Count == 1)
            {
                var selected = nodes.FirstOrDefault(n => n.Id == selectedNodeIds.First());
                if (selected != null)
                {
                    <form class="editor" @onsubmit="@(() => UpdateSelectedNode(selected))" @onsubmit:preventDefault="true">
                        <p><strong>Редактирование узла</strong></p>
                        <input style="width: 100%;" placeholder="Название узла" @bind="selected.Title" readonly="@isReadOnly" />
                        <input style="width: 100%;" placeholder="Описание" @bind="selected.Description" readonly="@isReadOnly" />
                        <select style="width: 100%;" @bind="selected.Type" disabled="@isReadOnly">
                            <option>Тема</option><option>Навык</option><option>Проект</option><option>Тест</option><option>Контрольная точка</option>
                        </select>
                        <select style="width: 100%;" @bind="selected.Difficulty" disabled="@isReadOnly">
                            <option>Beginner</option><option>Intermediate</option><option>Advanced</option>
                        </select>
                        
                        <select style="width: 100%;" @bind="selected.Status">
                            <option value="Planned">Не начато</option>
                            <option value="In Progress">В процессе</option>
                            <option value="Completed">Завершено</option>
                        </select>
                        <div style="display:flex; align-items:center; gap:0.5rem; margin-top:0.4rem; width: 100%;">
                            <input type="range" min="0" max="100" @bind="selected.Progress" style="flex:1;" />
                            <span style="font-size:0.8rem; min-width: 35px;">@selected.Progress%</span>
                        </div>
                        <button type="submit" style="width: 100%; margin-top: 0.5rem;">Сохранить изменения</button>
                    </form>

                    @if (!isReadOnly)
                    {
                        <div class="tool-row" style="margin-top: 1rem;">
                            <button type="button" style="background-color: #fee2e2; color: #b91c1c; border: 1px solid #fca5a5; width: 100%;" @onclick="DeleteSelectedNodes">🗑 Удалить узел</button>
                        </div>
                    }
                }
            }
            else
            {
                @if (!isReadOnly)
                {
                    <form class="editor" @onsubmit="CreateNode" @onsubmit:preventDefault="true">
                        <p><strong>Создание нового узла</strong></p>
                        <input style="width: 100%;" placeholder="Название узла" @bind="newNodeTitle"/>
                        <input style="width: 100%;" placeholder="Описание" @bind="newNodeDescription"/>
                        <select style="width: 100%;" @bind="newNodeType">
                            <option>Тема</option><option>Навык</option><option>Проект</option><option>Тест</option><option>Контрольная точка</option>
                        </select>
                        <button type="submit" style="width: 100%; margin-top: 0.5rem;">Добавить узел</button>
                    </form>
                }
                else
                {
                    <div style="padding: 1rem; background: #faf5ff; border: 1px solid #e9d5ff; border-radius: 10px; font-size: 0.85rem; color: #6b21a8; text-align: center;">
                        💡 Кликните по любому узлу на холсте, чтобы отметить статус изучения темы преподавателя.
                    </div>
                }
            }
        }
    </aside>
</div>

@if (_showExportModal)
{
    <div class="jiroad-modal-backdrop" @onclick="CloseExportModal">
        <div class="jiroad-modal-window" @onclick:stopPropagation>
            <header class="jiroad-modal-header">
                <h3>📦 Экспорт дорожной карты</h3>
                <button class="jiroad-modal-close-btn" @onclick="CloseExportModal">×</button>
            </header>
            
            <main class="jiroad-modal-body">
                <div class="modal-form-group">
                    <label>📄 Формат экспорта данных:</label>
                    <select @bind="_exportFormat">
                        <option value="json">JSON файл (.json)</option>
                        <option value="text">Простой текст этапов (.txt)</option>
                        <option value="markdown">Markdown document (.md)</option>
                    </select>
                </div>

                <div class="modal-form-group">
                    <label>🔍 Что именно выгрузить:</label>
                    <select @bind="_exportScope">
                        <option value="all">Всю карту целиком (Структура, узлы, связи)</option>
                        <option value="nodes">Только этапы (Названия, прогресс и описание)</option>
                        <option value="edges">Только связи между этапами</option>
                    </select>
                </div>

                <div class="modal-form-group">
                    <label>🚀 Куда экспортировать данные:</label>
                    <select @bind="_exportTarget">
                        <option value="download">Скачать готовым файлом в браузер</option>
                        <option value="clipboard">Скопировать текст в буфер обмена</option>
                    </select>
                </div>

                @if (!string.IsNullOrEmpty(_exportAlertMessage))
                {
                    <div class="modal-alert-box">
                        @_exportAlertMessage
                    </div>
                }
            </main>

            <footer class="jiroad-modal-footer">
                <button class="ghost" @onclick="CloseExportModal">Отмена</button>
                <button class="cta" @onclick="ExecuteCustomExport">Подтвердить экспорт</button>
            </footer>
        </div>
    </div>
}

@code {
    [Parameter] public int RoadmapId { get; set; }

    private enum ToolMode { Select, Pan, Connect }
    private string userRole = "Student";
    private string token = "";
    private bool _wasDragged = false;
    private ToolMode tool = ToolMode.Select;
    private readonly HashSet<int> selectedNodeIds = [];
    private int selectedEdgeId = 0;
    private int _hoveredEdgeId = 0; 
    private int pendingSourceNodeId;
    private List<NodeVm> nodes = new();
    private List<EdgeVm> edges = new();

    private string edgeType = "Зависимость";
    private string newNodeTitle = "";
    private string newNodeDescription = "";
    private string newNodeType = "Тема";

    private double zoom = 1;
    private double offsetX = 0;
    private double offsetY = 0;
    private bool panning;
    private double startPanX;
    private double startPanY;
    private int draggingNodeId;
    private double nodeStartX;
    private double nodeStartY;
    private double pointerStartX;
    private double pointerStartY;
    
    private bool isReadOnly = false;

    private string TransformStyle => $"transform: translate({offsetX.ToString(CultureInfo.InvariantCulture)}px, {offsetY.ToString(CultureInfo.InvariantCulture)}px) scale({zoom.ToString(CultureInfo.InvariantCulture)});";
    private bool _isDrawingEdge = false;
    private NodeVm? _edgeSourceNode = null;
    private double _currentMouseX = 0;
    private double _currentMouseY = 0;
    private bool _isSavingNow = false;
    private bool _justSavedAlert = false;

    private bool _showExportModal = false;
    private string _exportFormat = "json";
    private string _exportScope = "all";
    private string _exportTarget = "download";
    private string _exportAlertMessage = "";
    private readonly Stack<string> _undoStack = new();
    private readonly Stack<string> _redoStack = new();

    private class BoundingRect { public double Left { get; set; } public double Top { get; set; } }

    private class HistorySnapshot
    {
        public List<NodeVm> Nodes { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        token = await Js.InvokeAsync<string>("jiroad.loadToken");
        if (!string.IsNullOrWhiteSpace(token))
        {
            try
            {
                var handler = new JwtSecurityTokenHandler();
                var jwtToken = handler.ReadJwtToken(token);
                userRole = jwtToken.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role || c.Type == "role")?.Value ?? "Student";
                
                if (userRole == "Student")
                {
                    isReadOnly = true;
                }
            }
            catch { userRole = "Student"; isReadOnly = true; }
        }
        await Load();
    }

    private void NavigateToAnalytics()
    {
        Nav.NavigateTo($"/analytics/{RoadmapId}");
    }

    private void SaveHistoryState()
    {
        if (isReadOnly) return;
        var snapshot = new HistorySnapshot
        {
            Nodes = nodes.Select(n => new NodeVm
            {
                Id = n.Id, Title = n.Title, Description = n.Description, Type = n.Type,
                Difficulty = n.Difficulty, Status = n.Status, Progress = n.Progress, Tags = n.Tags,
                X = n.X, Y = n.Y
            }).ToList()
        };
        _undoStack.Push(JsonSerializer.Serialize(snapshot));
        _redoStack.Clear();
    }

    private void Undo()
    {
        if (!_undoStack.Any() || isReadOnly) return;
        var currentSnapshot = new HistorySnapshot
        {
            Nodes = nodes.Select(n => new NodeVm
            {
                Id = n.Id, Title = n.Title, Description = n.Description, Type = n.Type,
                Difficulty = n.Difficulty, Status = n.Status, Progress = n.Progress, Tags = n.Tags,
                X = n.X, Y = n.Y
            }).ToList()
        };
        _redoStack.Push(JsonSerializer.Serialize(currentSnapshot));

        var rawState = _undoStack.Pop();
        var previousState = JsonSerializer.Deserialize<HistorySnapshot>(rawState);
        if (previousState != null)
        {
            nodes = previousState.Nodes;
            _ = SaveEntireRoadmapExplicitly();
        }
    }

    private void Redo()
    {
        if (!_redoStack.Any() || isReadOnly) return;
        var currentSnapshot = new HistorySnapshot
        {
            Nodes = nodes.Select(n => new NodeVm
            {
                Id = n.Id, Title = n.Title, Description = n.Description, Type = n.Type,
                Difficulty = n.Difficulty, Status = n.Status, Progress = n.Progress, Tags = n.Tags,
                X = n.X, Y = n.Y
            }).ToList()
        };
        _undoStack.Push(JsonSerializer.Serialize(currentSnapshot));

        var rawState = _redoStack.Pop();
        var nextState = JsonSerializer.Deserialize<HistorySnapshot>(rawState);
        if (nextState != null)
        {
            nodes = nextState.Nodes;
            _ = SaveEntireRoadmapExplicitly();
        }
    }
    
    private void NavigateToTests()
    {
        Nav.NavigateTo($"/roadmap/{RoadmapId}/tests");
    }
    
    private void SetTool(ToolMode value)
    {
        if (isReadOnly && value == ToolMode.Connect) return;
        tool = value;
        if (tool != ToolMode.Connect) pendingSourceNodeId = 0;
        selectedNodeIds.Clear();
        selectedEdgeId = 0;
        _hoveredEdgeId = 0;
    }

    private static string ToolName(ToolMode mode) => mode switch
    {
        ToolMode.Select => "Выбор и редактирование",
        ToolMode.Pan => "Перемещение по холсту",
        ToolMode.Connect => "Управление связями",
        _ => "Выбор"
    };

    private HttpClient Client()
    {
        // ИСПРАВЛЕНО ДЛЯ DOCKER: Динамическое переключение адреса хоста внутри Docker-сети
        string baseAddress = Nav.BaseUri;
        if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
        {
            baseAddress = "http://127.0.0.1:8080/";
        }

        var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
        http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return http;
    }

    private async Task Load()
    {
        using var http = Client();
        var apiNodes = await http.GetFromJsonAsync<List<NodeDto>>($"/api/roadmap/{RoadmapId}/nodes") ?? new();
        var apiEdges = await http.GetFromJsonAsync<List<EdgeVm>>($"/api/roadmap/{RoadmapId}/edges") ?? new();
        nodes = apiNodes.Select(n => new NodeVm
        {
            Id = n.Id, Title = n.Title, Description = n.Description, Type = LocalizeType(n.Type),
            Difficulty = string.IsNullOrWhiteSpace(n.Difficulty) ? "Beginner" : n.Difficulty,
            Status = string.IsNullOrWhiteSpace(n.Status) ? "Planned" : n.Status, Progress = n.Progress,
            Tags = n.Tags ?? "", X = n.PositionX, Y = n.PositionY
        }).ToList();

        edges = apiEdges;
        _undoStack.Clear();
        _redoStack.Clear();
        StateHasChanged();
    }

    private static string LocalizeType(string type) => type switch
    {
        "Topic" => "Тема",
        "Skill" => "Навык",
        "Project" => "Проект",
        "Test" => "Тест",
        "Milestone" => "Контрольная точка",
        _ => type
    };

    private async Task CreateNode()
    {
        if (isReadOnly) return;
        SaveHistoryState();
        using var http = Client();
        
        double targetX = 150;
        double targetY = 150;
        if (nodes.Count > 0)
        {
            var rightmostNode = nodes.OrderByDescending(n => n.X).First();
            targetX = rightmostNode.X + 280; 
            targetY = rightmostNode.Y;       
        }

        var payload = new
        {
            RoadmapId = RoadmapId,
            Title = string.IsNullOrWhiteSpace(newNodeTitle) ? $"Этап {nodes.Count + 1}" : newNodeTitle,
            Description = newNodeDescription, Resource = "", Type = NormalizeNodeType(newNodeType),
            Difficulty = "Beginner", Status = "Planned", Progress = 0, Tags = "",
            PositionX = Math.Round(targetX, 2), PositionY = Math.Round(targetY, 2)
        };
        var response = await http.PostAsJsonAsync("/api/roadmap/nodes", payload);
        if (response.IsSuccessStatusCode)
        {
            var createdDto = await response.Content.ReadFromJsonAsync<NodeDto>();
            if (createdDto != null)
            {
                var newVm = new NodeVm
                {
                    Id = createdDto.Id, Title = createdDto.Title, Description = createdDto.Description,
                    Type = LocalizeType(createdDto.Type), Difficulty = createdDto.Difficulty,
                    Status = createdDto.Status, Progress = createdDto.Progress, Tags = createdDto.Tags,
                    X = createdDto.PositionX, Y = createdDto.PositionY
                };
                nodes.Add(newVm);
                newNodeTitle = "";
                newNodeDescription = "";
                StateHasChanged();
            }
        }
    }

    private Task CreateNodeQuick()
    {
        if (isReadOnly) return Task.CompletedTask;
        newNodeTitle = $"Узел {nodes.Count + 1}";
        newNodeDescription = "Быстрый узел";
        return CreateNode();
    }

    private async Task<EdgeVm?> CreateEdge(int fromNodeId, int toNodeId, string type)
    {
        if (isReadOnly) return null;
        using var http = Client();
        var color = type switch
        {
            "Альтернативный путь" => "#8b5cf6",
            "Параллельный путь" => "#2563eb",
            "Ссылка" => "#0ea5e9",
            _ => "#6078a8"
        };
        var dashed = type is "Альтернативный путь" or "Ссылка";
        var payload = new
        {
            RoadmapId = RoadmapId, FromNodeId = fromNodeId, ToNodeId = toNodeId,
            EdgeType = type, IsDashed = dashed, Thickness = type == "Параллельный путь" ? 3 : 2, Color = color
        };
        var response = await http.PostAsJsonAsync("/api/roadmap/edges", payload);
        if (response.IsSuccessStatusCode)
        {
            var newEdge = await response.Content.ReadFromJsonAsync<EdgeVm>();
            if (newEdge != null)
            {
                edges.Add(newEdge);
                StateHasChanged();
                return newEdge;
            }
        }
        return null;
    }

    private async Task DeleteSelectedNodes()
    {
        if (selectedNodeIds.Count == 0 || isReadOnly) return;
        SaveHistoryState();
        using var http = Client();
        foreach (var nodeId in selectedNodeIds.ToList())
        {
            await http.DeleteAsync($"/api/roadmap/nodes/{nodeId}");
        }
        selectedNodeIds.Clear();
        await Load();
    }

    private async Task DeleteLastEdge()
    {
        if (isReadOnly) return;
        var edge = edges.LastOrDefault();
        if (edge is null) return;
        using var http = Client();
        await http.DeleteAsync($"/api/roadmap/edges/{edge.Id}");
        edges.Remove(edge);
        if (selectedEdgeId == edge.Id) selectedEdgeId = 0;
        StateHasChanged();
    }

    private void CancelSelection() { }

    private void SelectEdge(int edgeId)
    {
        if (tool == ToolMode.Select || tool == ToolMode.Pan)
        {
            selectedNodeIds.Clear();
            selectedEdgeId = edgeId;
            StateHasChanged();
        }
    }

    private async Task DeleteSelectedEdge()
    {
        if (selectedEdgeId == 0 || isReadOnly) return;
        using var http = Client();
        var response = await http.DeleteAsync($"/api/roadmap/edges/{selectedEdgeId}");
        if (response.IsSuccessStatusCode)
        {
            var edgeToRemove = edges.FirstOrDefault(e => e.Id == selectedEdgeId);
            if (edgeToRemove != null) edges.Remove(edgeToRemove);
            selectedEdgeId = 0;
            StateHasChanged();
        }
    }

    private async Task DeleteSpecificEdgeFromList(int edgeId)
    {
        if (isReadOnly) return;
        using var http = Client();
        var response = await http.DeleteAsync($"/api/roadmap/edges/{edgeId}");
        if (response.IsSuccessStatusCode)
        {
            var edgeToRemove = edges.FirstOrDefault(e => e.Id == edgeId);
            if (edgeToRemove != null) edges.Remove(edgeToRemove);
            if (selectedEdgeId == edgeId) selectedEdgeId = 0;
            if (_hoveredEdgeId == edgeId) _hoveredEdgeId = 0;
            StateHasChanged();
        }
    }

    private void OpenExportModal() => _showExportModal = true;
    private void CloseExportModal() => _showExportModal = false;

    private async Task ExecuteCustomExport()
    {
        _exportAlertMessage = "";
        string outputText = "";
        string fileName = $"roadmap-{RoadmapId}";

        if (_exportFormat == "json")
        {
            fileName += ".json";
            using var http = Client();
            var rawJson = await http.GetStringAsync($"/api/roadmap/{RoadmapId}/export/json");
            if (_exportScope == "all") outputText = rawJson;
            else if (_exportScope == "nodes") outputText = JsonSerializer.Serialize(nodes);
            else if (_exportScope == "edges") outputText = JsonSerializer.Serialize(edges);
        }
        else if (_exportFormat == "text" || _exportFormat == "markdown")
        {
            var sb = new StringBuilder();
            bool isMd = _exportFormat == "markdown";
            fileName += isMd ? ".md" : ".txt";

            if (isMd) sb.AppendLine($"# Дорожная карта #{RoadmapId}\n");
            else sb.AppendLine($"=== ДОРОЖНАЯ КАРТА #{RoadmapId} ===\n");

            if (_exportScope is "all" or "nodes")
            {
                sb.AppendLine(isMd ? "## 📌 Этапы и Темы обучения" : "--- ЭТАПЫ И ОБУЧЕНИЕ ---");
                foreach (var n in nodes)
                {
                    sb.AppendLine(isMd ? $"### 🔘 {n.Title}" : $"• {n.Title}");
                    sb.AppendLine($"  Тип: {n.Type} | Прогресс: {n.Progress}% | Status: {GetStatusText(n.Status)}");
                    if (!string.IsNullOrWhiteSpace(n.Description)) sb.AppendLine($"  Описание: {n.Description}");
                    sb.AppendLine();
                }
            }

            if (_exportScope is "all" or "edges")
            {
                sb.AppendLine(isMd ? "## ↝ Связи и Зависимости" : "--- СВЯЗИ И ПОРЯДОК ---");
                foreach (var e in edges)
                {
                    var from = nodes.FirstOrDefault(x => x.Id == e.FromNodeId)?.Title ?? $"Узел {e.FromNodeId}";
                    var to = nodes.FirstOrDefault(x => x.Id == e.ToNodeId)?.Title ?? $"Узел {e.ToNodeId}";
                    sb.AppendLine($"  [{from}] ── ({e.EdgeType}) ──> [{to}]");
                }
            }
            outputText = sb.ToString();
        }

        if (_exportTarget == "download")
        {
            await Js.InvokeVoidAsync("jiroad.download", fileName, outputText);
            _exportAlertMessage = "🚀 Файл успешно сгенерирован и скачан!";
        }
        else if (_exportTarget == "clipboard")
        {
            await Js.InvokeVoidAsync("navigator.clipboard.writeText", outputText);
            _exportAlertMessage = "📋 Данные скопированы в буфер обмена!";
        }
        StateHasChanged();
    }

