@page "/help"
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Интерактивная справка | JIroad</PageTitle>

<div class="container-fluid mt-3 mb-5 px-4" style="max-width: 1440px; font-family: system-ui, -apple-system, sans-serif;">
    
    <!-- ВЕРХНИЙ ИНФОРМАЦИОННЫЙ БАННЕР -->
    <div class="card shadow-sm border-0 p-4 mb-4 rounded-3 text-white" style="background: linear-gradient(135deg, #1e3a8a, #2563eb);">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h1 class="fw-bold mb-1 text-white" style="font-size: 1.85rem;">
                    <span class="bi bi-journal-bookmark-fill me-2"></span> База знаний и руководство пользователя JIroad
                </h1>
                <p class="mb-0 opacity-90 fs-5">Исчерпывающий интерактивный гид по всем кнопкам, меню, возможностям и сценариям работы.</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-light text-primary fw-bold shadow-sm" @onclick="@ExpandAll">
                    <span class="bi bi-plus-square-fill me-1"></span> Развернуть всё
                </button>
                <button class="btn btn-outline-light fw-bold" @onclick="@CollapseAll">
                    <span class="bi bi-dash-square-fill me-1"></span> Свернуть всё
                </button>
            </div>
        </div>
    </div>

    <!-- ДВУХКОЛОННЫЙ МАКЕТ СПРАВКИ -->
    <div class="row">
        
        <!-- ЛЕВОЕ ИЕРАРХИЧЕСКОЕ МЕНЮ (НАВИГАЦИЯ С АВТОРАСКРЫТИЕМ) -->
        <div class="col-xl-3 col-lg-4 mb-4">
            <div class="card shadow-sm border-1 sticky-top" style="top: 15px; max-height: 85vh; overflow-y: auto; border-radius: 12px; border-color: #e2e8f0;">
                <div class="card-header bg-dark text-white fw-bold py-3">
                    <span class="bi bi-list-nested text-warning me-2"></span> Содержание руководства
                </div>
                <div class="list-group list-group-flush small">
                    
                    <button type="button" @onclick="@(() => ScrollToSection(10, "user-scenario"))" class="list-group-item list-group-item-action py-3 text-start fw-bold text-dark style-scenario-btn" style="background-color: #fef08a;">
                        <span class="bi bi-bezier text-danger me-2"></span> Сценарий: От старта до 100%
                    </button>
                    
                    <button type="button" @onclick="@(() => ScrollToSection(0, "user-intro"))" class="list-group-item list-group-item-action py-2.5 text-start fw-bold text-primary border-bottom">
                        <span class="bi bi-compass-fill me-2"></span> Как устроена система?
                    </button>
                    
                    <div class="fw-bold px-3 py-2 bg-light border-bottom text-uppercase text-muted" style="font-size: 10px; letter-spacing: 0.05em;">1. Доступ и Профиль</div>
                    <button type="button" @onclick="@(() => ScrollToSection(1, "user-auth"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-lock-fill text-success me-2"></span> Вход и Регистрация
                    </button>
                    <button type="button" @onclick="@(() => ScrollToSection(1, "user-profile"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-person-badge-fill text-success me-2"></span> Личный кабинет
                    </button>
                    
                    <div class="fw-bold px-3 py-2 bg-light border-bottom text-uppercase text-muted" style="font-size: 10px; letter-spacing: 0.05em;">2. Панель управления</div>
                    <button type="button" @onclick="@(() => ScrollToSection(2, "user-dash-metrics"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-bar-chart-fill text-primary me-2"></span> Индикаторы и Статистика
                    </button>
                    <button type="button" @onclick="@(() => ScrollToSection(2, "user-dash-actions"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-collection-play-fill text-primary me-2"></span> Список ваших карт
                    </button>
                    
                    <div class="fw-bold px-3 py-2 bg-light border-bottom text-uppercase text-muted" style="font-size: 10px; letter-spacing: 0.05em;">3. Графический холст (Canvas)</div>
                    <button type="button" @onclick="@(() => ScrollToSection(3, "user-canvas-tools"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-bezier2 text-warning me-2"></span> Боковые инструменты холста
                    </button>
                    <button type="button" @onclick="@(() => ScrollToSection(3, "user-canvas-top"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-layout-sidebar-inset text-warning me-2"></span> Верхняя панель действий
                    </button>
                    <button type="button" @onclick="@(() => ScrollToSection(3, "user-canvas-nodes"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-node-plus text-warning me-2"></span> Управление узлами и связями
                    </button>
                    
                    <div class="fw-bold px-3 py-2 bg-light border-bottom text-uppercase text-muted" style="font-size: 10px; letter-spacing: 0.05em;">4. Свойства и Материалы</div>
                    <button type="button" @onclick="@(() => ScrollToSection(4, "user-props-form"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-sliders text-info me-2"></span> Параметры выбранной темы
                    </button>
                    <button type="button" @onclick="@(() => ScrollToSection(4, "user-props-materials"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-journal-text text-info me-2"></span> Лекции, Ссылки и Чек-листы
                    </button>
                    
                    <div class="fw-bold px-3 py-2 bg-light border-bottom text-uppercase text-muted" style="font-size: 10px; letter-spacing: 0.05em;">5. Генерация через ИИ</div>
                    <button type="button" @onclick="@(() => ScrollToSection(5, "user-ai-fields"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-robot text-purple me-2"></span> Автогенератор Gemini
                    </button>
                    
                    <div class="fw-bold px-3 py-2 bg-light border-bottom text-uppercase text-muted" style="font-size: 10px; letter-spacing: 0.05em;">6. Контроль знаний (Тесты)</div>
                    <button type="button" @onclick="@(() => ScrollToSection(6, "user-tests-manage"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-patch-question text-danger me-2"></span> Создание вопросов
                    </button>
                    <button type="button" @onclick="@(() => ScrollToSection(6, "user-tests-run"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-check-all text-danger me-2"></span> Сдача теста студентом
                    </button>
                    
                    <div class="fw-bold px-3 py-2 bg-light border-bottom text-uppercase text-muted" style="font-size: 10px; letter-spacing: 0.05em;">7. Команда и Экспорт данных</div>
                    <button type="button" @onclick="@(() => ScrollToSection(7, "user-collab-sync"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-people-fill text-secondary me-2"></span> Совместный режим онлайн
                    </button>
                    <button type="button" @onclick="@(() => ScrollToSection(7, "user-export-modal"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-download text-secondary me-2"></span> Настройки окна экспорта
                    </button>
                    
                    <div class="fw-bold px-3 py-2 bg-light border-bottom text-uppercase text-muted" style="font-size: 10px; letter-spacing: 0.05em;">8. Сообщество и Спецроли</div>
                    <button type="button" @onclick="@(() => ScrollToSection(8, "user-library"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-globe2 text-dark me-2"></span> Библиотека шаблонов
                    </button>
                    <button type="button" @onclick="@(() => ScrollToSection(9, "user-roles"))" class="list-group-item list-group-item-action ps-4 py-2 text-start">
                        <span class="bi bi-mortarboard-fill text-dark me-2"></span> Инструменты Ментора и Админа
                    </button>
                </div>
            </div>
        </div>

        <!-- ПРАВАЯ ЧАСТЬ: ДЕТАЛИЗИРОВАННОЕ ОПИСАНИЕ И СЦЕНАРИЙ -->
        <div class="col-xl-9 col-lg-8">
            
            <!-- ВВОДНЫЙ РАЗДЕЛ -->
            <div id="user-intro" class="p-4 rounded-3 border mb-4 shadow-sm" style="background-color: #f8fafc; border-color: #e2e8f0;">
                <h4 class="fw-bold text-dark mb-2"><span class="bi bi-info-circle-fill text-primary me-2"></span> 0. Принцип работы интерфейса</h4>
                <p class="mb-0 text-secondary leading-relaxed">
                    Данный справочник разработан для быстрого изучения всех элементов управления программы. Каждое поле, кнопка и флажок описаны с позиции того, что вы видите на экране и к какому результату приводит клик мыши.
                </p>
            </div>

            <!-- ИЕРАРХИЧЕСКИЙ АККОРДЕОН -->
            <div class="accordion shadow-sm" id="userManualAccordion">
                
                <!-- РАЗДЕЛ 10: СКВОЗНОЙ ПОШАГОВЫЙ СЦЕНАРИЙ (ВЫНЕСЕН НАВЕРХ ДЛЯ УДОБСТВА) -->
                <div class="accordion-item mb-3 border rounded-3 border-warning" id="user-scenario">
                    <h2 class="accordion-header">
                        <button class="accordion-button fw-bold text-dark bg-gradient fs-5" style="background-color: #fef08a;" type="button" @onclick="@(() => ToggleSection(10))">
                            <span class="bi bi-bezier text-danger me-2"></span> 🚀 Сквозной сценарий: Идеальный пошаговый процесс работы
                        </button>
                    </h2>
                    <div class="accordion-collapse collapse @(activeSections.Contains(10) ? "show" : "")">
                        <div class="accordion-body bg-white border-top">
                            <p class="lead text-dark">Пройдите эти 7 шагов, чтобы полностью освоить работу с дорожными картами в системе:</p>
                            
                            <div class="row g-4 mt-2">
                                <div class="col-12">
                                    <div class="p-3 rounded-3 border-start border-4 border-success bg-light shadow-sm">
                                        <h5><span class="badge bg-success me-2">Шаг 1</span> Создание фундамента (Авторизация и вход)</h5>
                                        <p class="small text-secondary mb-0">Зарегистрируйте аккаунт. Если вы учитесь с преподавателем, выберите роль <strong>Студент</strong> и введите код, который он вам выдал, чтобы ваши аккаунты связались.</p>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="p-3 rounded-3 border-start border-4 border-primary bg-light shadow-sm">
                                        <h5><span class="badge bg-primary me-2">Шаг 2</span> Инициализация новой карты</h5>
                                        <p class="small text-secondary mb-0">Находясь на Главной панели, нажмите кнопку <strong>«Создать Roadmap»</strong> или перейдите в <strong>«ИИ-Генератор»</strong>. Задайте параметры, выберите уровень сложности и нажмите фиксацию — перед вами откроется пустой или автоматически сгенерированный ИИ холст.</p>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="p-3 rounded-3 border-start border-4 border-warning bg-light shadow-sm">
                                        <h5><span class="badge bg-warning text-dark me-2">Шаг 3</span> Моделирование структуры на холсте</h5>
                                        <p class="small text-secondary mb-0">Используя левую боковую панель инструментов, нажмите на значок <strong>＋</strong>, чтобы добавить новые темы-узлы. Переключитесь на инструмент <strong>«Прицел»</strong>, расставьте темы в удобном порядке, зажимая их левой кнопкой мыши. Соедините их стрелочками, протягивая линии от коннекторов, чтобы задать порядок изучения блоков. Не забудьте нажать зелёную кнопку <strong>«Сохранить карту»</strong> внизу.</p>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="p-3 rounded-3 border-start border-4 border-info bg-light shadow-sm">
                                        <h5><span class="badge bg-info text-dark me-2">Шаг 4</span> Наполнение тем знаниями</h5>
                                        <p class="small text-secondary mb-0">Кликните по любому узлу, чтобы справа открылась его карточка параметров. Напишите конспект лекции в центральное текстовое поле, прикрепите полезные внешние ссылки кнопкой <strong>«Добавить внешнюю ссылку»</strong> и создайте список практических шагов через кнопку <strong>«Добавить пункт чек-листа»</strong>.</p>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="p-3 rounded-3 border-start border-4 border-danger bg-light shadow-sm">
                                        <h5><span class="badge bg-danger me-2">Шаг 5</span> Интеграция системы контроля</h5>
                                        <p class="small text-secondary mb-0">Нажмите верхнюю кнопку <strong>«Тесты карты»</strong>. Создайте проверочный тест, добавьте вопросы, варианты ответов и обязательно отметьте круглыми флажками (Radio) правильные варианты ответов, чтобы система могла проверять знания студента.</p>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="p-3 rounded-3 border-start border-4 border-secondary bg-light shadow-sm">
                                        <h5><span class="badge bg-secondary me-2">Шаг 6</span> Прохождение и обучение</h5>
                                        <p class="small text-secondary mb-0">Перейдите на холст в режим обучения. Кликайте по открытым узлам, изучайте теорию, переходите по ссылкам и отмечайте выполненные шаги в чек-листах. Запускайте тесты кнопкой <strong>«Начать тестирование»</strong> и успешно сдавайте их, чтобы разблокировать доступ к следующим сложным темам графа.</p>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="p-3 rounded-3 border-start border-4 border-dark bg-light shadow-sm">
                                        <h5><span class="badge bg-dark me-2">Шаг 7</span> Аналитика и публикация</h5>
                                        <p class="small text-secondary mb-0">Следите за заполнением шкал прогресса на Главной панели. Нажмите кнопку <strong>«Аналитика»</strong>, чтобы увидеть детальные отчеты успеваемости. Если ваша карта получилась отличной — нажмите <strong>«Опубликовать в общие шаблоны»</strong>, чтобы поделиться ею со всем сообществом платформы.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- РАЗДЕЛ 1: АВТОРИЗАЦИЯ И ПРОФИЛЬ -->
                <div class="accordion-item mb-3 border rounded-3" id="user-auth">
                    <h2 class="accordion-header">
                        <button class="accordion-button fw-bold text-dark bg-light fs-5" type="button" @onclick="@(() => ToggleSection(1))">
                            <span class="bi bi-shield-lock-fill text-primary me-2"></span> 1. Раздел: Регистрация, вход в систему и личный аккаунт
                        </button>
                    </h2>
                    <div class="accordion-collapse collapse @(activeSections.Contains(1) ? "show" : "")">
                        <div class="accordion-body bg-white border-top">
                            
                            <h5><span class="bi bi-door-open-fill text-success me-2"></span> Форма входа в приложение (Login.razor)</h5>
                            <p class="text-muted">Используется для получения доступа к вашим личным дорожным картам.</p>
                            <ul>
                                <li class="mb-2"><strong>Поле «Электронная почта (Email)»:</strong> Текстовая строка для ввода вашего адреса. Система проверяет наличие знака собачки (<code>@@</code>). Если адрес указан некорректно, вход заблокируется.</li>
                                <li class="mb-2"><strong>Поле «Пароль»:</strong> Секретное текстовое поле. Вводимые знаки скрываются точками. Для безопасности ваш пароль должен быть длиннее 6 символов.</li>
                                <li class="mb-2"><strong>Кнопка «Войти» <span class="badge bg-primary"><span class="bi bi-box-arrow-in-right"></span></span>:</strong> Считывает введённые данные, проверяет их правильность и перенаправляет вас на вашу личную рабочую зону.</li>
                            </ul>

                            <h5 class="mt-4"><span class="bi bi-person-plus-fill text-success me-2"></span> Форма создания нового аккаунта (Register.razor)</h5>
                            <p class="text-muted">Предназначена для новых пользователей.</p>
                            <ul>
                                <li class="mb-2"><strong>Поле «Имя пользователя»:</strong> Ваш уникальный никнейм в системе, по которому вас смогут находить наставники и друзья.</li>
                                <li class="mb-2"><strong>Поле «Подтверждение пароля»:</strong> Защитное поле. Сюда нужно ввести пароль ещё раз. Если символы не совпадут с первым полем, приложение выдаст предупреждение.</li>
                                <li class="mb-2"><strong>Кнопка «Зарегистрироваться» <span class="badge bg-success">✓</span>:</strong> Создаёт ваш чистый профиль в системе и сразу выполняет автоматический вход.</li>
                            </ul>

                            <h5 class="mt-4" id="user-profile"><span class="bi bi-person-circle text-success me-2"></span> Личный кабинет (Profile.razor) и выход</h5>
                            <ul>
                                <li class="mb-2"><strong>Визуальный круглый значок «U» в верхнем углу меню:</strong> Индикатор вашей активности. Если он светится синим цветом, значит, вы успешно авторизованы. При наведении мыши всплывает подсказка «Профиль активен».</li>
                                <li class="mb-2"><strong>Поле ввода «Квалификация / Специализация»:</strong> Текстовая строка на странице профиля. Вы можете написать туда свою текущую учебную роль (например: *«Студент-программист»*). Кнопка <strong>«Обновить данные»</strong> сохраняет этот текст.</li>
                                <li class="mb-2"><strong>Кнопка «Выход» <span class="text-danger fw-bold"><span class="bi bi-box-arrow-right"></span></span> внизу меню:</strong> Мгновенно завершает вашу текущую сессию, полностью очищает память браузера от ваших данных авторизации и переводит сайт в режим гостя.</li>
                            </ul>

                        </div>
                    </div>
                </div>

                <!-- РАЗДЕЛ 2: ДАШБОРД -->
                <div class="accordion-item mb-3 border rounded-3" id="user-dash-metrics">
                    <h2 class="accordion-header">
                        <button class="accordion-button fw-bold text-dark bg-light fs-5" type="button" @onclick="@(() => ToggleSection(2))">
                            <span class="bi bi-grid-fill text-primary me-2"></span> 2. Раздел: Рабочая зона «Мои Roadmap» (Dashboard.razor)
                        </button>
                    </h2>
                    <div class="accordion-collapse collapse @(activeSections.Contains(2) ? "show" : "")">
                        <div class="accordion-body bg-white border-top">
                            
                            <h5><span class="bi bi-speedometer2 text-primary me-2"></span> Общие индикаторы прогресса (Блоки метрик)</h5>
                            <p class="text-muted">Верхняя панель наглядно демонстрирует вашу общую успеваемость по всем предметам:</p>
                            <div class="row g-3 mb-4">
                                <div class="col-md-3">
                                    <div class="p-3 border rounded bg-light">
                                        <div class="small text-muted fw-bold">📋 ВСЕГО КАРТ</div>
                                        <div class="fs-4 fw-bold">Отображает общее количество дорожных карт в вашем кабинете.</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="p-3 border rounded bg-light" style="border-left: 4px solid #22c55e !important;">
                                        <div class="small text-success fw-bold">🏆 ОСВОЕНО (100%)</div>
                                        <div class="fs-4 fw-bold">Количество карт, в которых вы закрыли абсолютно все этапы.</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="p-3 border rounded bg-light" style="border-left: 4px solid #3b82f6 !important;">
                                        <div class="small text-primary fw-bold">⏳ В ПРОЦЕССЕ</div>
                                        <div class="fs-4 fw-bold">Карты, которые вы сейчас активно изучаете и выполняете задачи.</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="p-3 border rounded bg-light" style="border-left: 4px solid #6366f1 !important;">
                                        <div class="small text-purple fw-bold">📈 СРЕДНИЙ ПРОГРЕСС</div>
                                        <div class="fs-4 fw-bold">Общий средний процент выполнения по всем вашим трекам вместе взятым.</div>
                                    </div>
                                </div>
                            </div>

                            <h5 id="user-dash-actions"><span class="bi bi-collection-play-fill text-primary me-2"></span> Управление списком дорожных карт</h5>
                            <div class="table-responsive">
                                <table class="table table-bordered align-middle small">
