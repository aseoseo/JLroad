@page "/auth/register"
@using JIroad.Api
@using System.Net.Http.Json
@inject NavigationManager Nav
@inject IJSRuntime Js

<PageTitle>Регистрация | JIroad</PageTitle>

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center bg-light px-3 py-4" style="background-color: #f8fafc !important; font-family: system-ui, sans-serif;">
    <div class="card w-100 p-4 p-sm-5 border border-light-subtle rounded-4 shadow" style="max-width: 520px; background-color: #ffffff;">
        
        <div class="text-center mb-4">
            <h1 class="m-0 text-dark fw-bold h3" style="font-weight: 800;">Создать аккаунт JIroad</h1>
            <p class="m-0 text-secondary mt-2 small">Выберите формат обучения и начните строить траекторию знаний</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger py-2 px-3 small border-0 fw-medium mb-3 text-start">
                ⚠️ @errorMessage
            </div>
        }

        <EditForm Model="regModel" OnValidSubmit="HandleRegister">
            <div class="mb-3 text-start">
                <label class="form-label small fw-semibold text-secondary mb-1">Электронная почта</label>
                <input type="email" @bind="regModel.Email" required class="form-control form-control-lg text-sm" style="font-size: 0.95rem; border-radius: 8px;" placeholder="name@example.com" />
            </div>

            <div class="mb-3 text-start">
                <label class="form-label small fw-semibold text-secondary mb-1">Пароль</label>
                <input type="password" @bind="regModel.Password" required class="form-control form-control-lg text-sm" style="font-size: 0.95rem; border-radius: 8px;" placeholder="••••••••" />
            </div>

            <div class="mb-4 text-start">
                <label class="form-label small fw-semibold text-secondary mb-2">Кто вы?</label>
                <div class="d-flex flex-column gap-2">
                    
                    <div class="p-3 border border-2 rounded-3 d-flex align-items-center gap-3" 
                         style="cursor: pointer; transition: background 0.15s, border-color 0.15s; border-color: @(regModel.Role == "Mentor" ? "#2563eb" : "#e2e8f0") !important; background-color: @(regModel.Role == "Mentor" ? "#f8fafc" : "#ffffff");" 
                         @onclick="@(() => SetRole("Mentor"))">
                        <span class="fs-3">👨‍🏫</span>
                        <div class="text-truncate">
                            <div class="fw-bold text-dark small">Преподаватель (Ментор)</div>
                            <div class="text-muted text-wrap" style="font-size: 0.75rem; margin-top: 0.1rem;">Буду обучать студентов, проверять их холсты и тесты</div>
                        </div>
                    </div>

                    <div class="p-3 border border-2 rounded-3 d-flex align-items-center gap-3" 
                         style="cursor: pointer; transition: background 0.15s, border-color 0.15s; border-color: @(regModel.Role == "SelfTaught" ? "#2563eb" : "#e2e8f0") !important; background-color: @(regModel.Role == "SelfTaught" ? "#f8fafc" : "#ffffff");" 
                         @onclick="@(() => SetRole("SelfTaught"))">
                        <span class="fs-3">🧠</span>
                        <div class="text-truncate">
                            <div class="fw-bold text-dark small">Самообучающийся</div>
                            <div class="text-muted text-wrap" style="font-size: 0.75rem; margin-top: 0.1rem;">Изучаю дорожные карты независимо для себя</div>
                        </div>
                    </div>

                    <div class="p-3 border border-2 rounded-3 d-flex align-items-center gap-3" 
                         style="cursor: pointer; transition: background 0.15s, border-color 0.15s; border-color: @(regModel.Role == "Student" ? "#2563eb" : "#e2e8f0") !important; background-color: @(regModel.Role == "Student" ? "#f8fafc" : "#ffffff");" 
                         @onclick="@(() => SetRole("Student"))">
                        <span class="fs-3">🎒</span>
                        <div class="text-truncate">
                            <div class="fw-bold text-dark small">Работа с ментором (Ученик)</div>
                            <div class="text-muted text-wrap" style="font-size: 0.75rem; margin-top: 0.1rem;">У меня есть инвайт-код от моего преподавателя</div>
                        </div>
                    </div>

                </div>
            </div>

            @if (regModel.Role == "Student")
            {
                <div class="p-3 border rounded-3 mb-4 text-start" style="background-color: #f0fdf4; border-color: #bbf7d0;">
                    <label class="form-label small fw-bold text-success mb-1">Инвайт-код преподавателя</label>
                    <input type="text" @bind="regModel.MentorCode" required class="form-control form-control-lg text-uppercase fw-bold" style="border-color: #86efac; font-size: 1rem; letter-spacing: 0.05em; color: #14532d;" placeholder="Например: JR-123456" />
                </div>
            }

            <button type="submit" class="btn btn-primary btn-lg text-white w-100 fw-bold border-0 py-2 rounded-3" style="font-size: 1rem; box-shadow: 0 4px 12px rgba(37,99,235,0.15) !important;" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span>Регистрация...</span>
                }
                else
                {
                    <span>Зарегистрироваться</span>
                }
            </button>
        </EditForm>

        <div class="text-center mt-4 small text-secondary">
            Уже есть аккаунт? <a href="/auth/login" class="text-primary fw-bold text-decoration-none">Войти</a>
        </div>
    </div>
</div>

@code {
    private RegisterFormModel regModel = new() { Role = "SelfTaught" };
    private string errorMessage = "";
    private bool isSubmitting = false;

    private void SetRole(string role)
    {
        regModel.Role = role;
        if (role != "Student") regModel.MentorCode = null;
    }

    private async Task HandleRegister()
    {
        isSubmitting = true;
        errorMessage = "";
        try
        {
            // ИСПРАВЛЕНО: Умное переключение BaseAddress, если код выполняется внутри Docker-контейнера
            string baseAddress = Nav.BaseUri;
            if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
            {
                baseAddress = "http://127.0.0.1:8080/";
            }

            using var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
            var response = await http.PostAsJsonAsync("/api/auth/register", regModel);
            
            if (response.IsSuccessStatusCode)
            {
                var authData = await response.Content.ReadFromJsonAsync<AuthResponseDto>();
                if (authData != null)
                {
                    await Js.InvokeVoidAsync("jiroad.saveToken", authData.Token);
                    
                    if (authData.Role == "Mentor")
                    {
                        await Js.InvokeVoidAsync("alert", $"🎉 Аккаунт преподавателя создан!\nВаш уникальный код для подключения учеников: {authData.MentorCode}. Вы можете найти его в профиле.");
                        Nav.NavigateTo("/mentor/dashboard", forceLoad: true);
                    }
                    else
                    {
                        Nav.NavigateTo("/dashboard", forceLoad: true);
                    }
                }
            }
            else
            {
                errorMessage = await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка соединения с сервером: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class RegisterFormModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string Role { get; set; } = "";
        public string? MentorCode { get; set; }
    }

    public class AuthResponseDto
    {
        public string Token { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public string? MentorCode { get; set; }
    }
}