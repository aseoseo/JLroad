@page "/dashboard"
@layout WorkspaceLayout
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using JIroad.Api
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Мои Roadmap | JIroad</PageTitle>

<div class="container-fluid px-2 px-md-4 my-4" style="max-width: 1400px; font-family: system-ui, -apple-system, sans-serif;">

    <header class="d-flex flex-column flex-md-row justify-content-between align-items-md-center p-4 mb-4 bg-white border rounded-4 shadow-sm gap-3">
        <div>
            <h1 class="m-0 text-dark fw-bold fs-3" style="letter-spacing: -0.02em;">🗺️ Рабочая зона JIroad</h1>
            <p class="m-0 text-muted mt-2 small" style="font-size: 0.95rem;">Управляйте траекториями обучения, изучайте материалы и отслеживайте прогресс на бесконечном холсте</p>
        </div>
        <div class="d-flex flex-wrap flex-sm-nowrap gap-2">
            <button class="btn btn-light border border-secondary-subtle fw-semibold px-3 py-2 rounded-3 w-100 w-sm-auto" @onclick="NavigateToAiGenerator">🤖 ИИ-Генератор</button>
            <button class="btn btn-primary fw-semibold px-4 py-2 rounded-3 text-white border-0 shadow w-100 w-sm-auto" style="box-shadow: 0 4px 10px rgba(37, 99, 235, 0.2) !important;" @onclick="CreateNewRoadmap">+ Создать Roadmap</button>
        </div>
    </header>

    @if (isLoading)
    {
        <div class="d-flex flex-column justify-content-center align-items-center" style="height: 300px; gap: 1rem;">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
            <span class="text-muted fw-medium small">Загрузка вашего рабочего пространства...</span>
        </div>
    }
    else
    {
        @if (globalAnalytics != null && globalAnalytics.TotalRoadmaps > 0)
        {
            <section class="row g-3 mb-4">
                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="card h-100 p-3 bg-white border rounded-3 d-flex flex-row align-items-center gap-3 shadow-sm border-light-subtle">
                        <div class="fs-3 bg-light rounded-3 d-flex align-items-center justify-content-center" style="width: 52px; height: 52px;">📋</div>
                        <div>
                            <div class="text-uppercase text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Всего карт</div>
                            <div class="fs-3 fw-extrabold text-dark mt-1" style="font-weight: 800;">@globalAnalytics.TotalRoadmaps</div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="card h-100 p-3 bg-white border rounded-3 d-flex flex-row align-items-center gap-3 shadow-sm border-light-subtle" style="border-left: 4px solid #22c55e !important;">
                        <div class="fs-3 rounded-3 d-flex align-items-center justify-content-center" style="width: 52px; height: 52px; background-color: #f0fdf4;">🏆</div>
                        <div>
                            <div class="text-uppercase text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Освоено (100%)</div>
                            <div class="fs-3 fw-extrabold text-success mt-1" style="font-weight: 800;">@globalAnalytics.FullyCompletedRoadmaps</div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="card h-100 p-3 bg-white border rounded-3 d-flex flex-row align-items-center gap-3 shadow-sm border-light-subtle" style="border-left: 4px solid #3b82f6 !important;">
                        <div class="fs-3 rounded-3 d-flex align-items-center justify-content-center" style="width: 52px; height: 52px; background-color: #eff6ff;">⏳</div>
                        <div>
                            <div class="text-uppercase text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">В процессе</div>
                            <div class="fs-3 fw-extrabold text-primary mt-1" style="font-weight: 800;">@globalAnalytics.InProgressRoadmaps</div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-sm-6 col-xl-3">
                    <div class="card h-100 p-3 bg-white border rounded-3 d-flex flex-row align-items-center gap-3 shadow-sm border-light-subtle" style="border-left: 4px solid #6366f1 !important;">
                        <div class="fs-3 rounded-3 d-flex align-items-center justify-content-center" style="width: 52px; height: 52px; background-color: #f5f3ff;">📈</div>
                        <div>
                            <div class="text-uppercase text-muted fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Средний прогресс</div>
                            <div class="fs-3 fw-extrabold" style="font-weight: 800; color: #6366f1;">@globalAnalytics.AverageGlobalProgress%</div>
                        </div>
                    </div>
                </div>
            </section>
        }

        <section class="card border border-purple-subtle rounded-4 p-4 mb-5" style="background-color: #faf5ff;">
            <h2 class="h5 text-purple fw-bold mb-3 d-flex align-items-center gap-2" style="color: #6b21a8; font-weight: 700;">
                📝 Задания от вашего преподавателя (@studentTasks.Count)
            </h2>

            @if (!studentTasks.Any())
            {
                <p class="text-muted fst-italic m-0 small" style="color: #7c3aed !important;">У вас пока нет активных проверочных заданий от ментора.</p>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var task in studentTasks)
                    {
                        <div class="col-12 col-md-6 col-xl-4">
                            <div class="card h-100 bg-white border rounded-3 p-3 d-flex flex-column justify-content-between shadow-sm border-light-subtle" 
                                 style="border-top: 4px solid @(task.Status == "Approved" ? "#10b981" : task.Status == "Submitted" ? "#f59e0b" : task.Status == "Rejected" ? "#ef4444" : "#a855f7") !important;">
                                <div>
                                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                        <h4 class="h6 m-0 text-dark fw-bold text-truncate" style="max-width: 75%;">@task.Title</h4>
                                        <span class="badge bg-light text-secondary border small py-1 px-2">
                                            @(task.IsGroupTask ? "👥 Группа" : "👤 Личное")
                                        </span>
                                    </div>
                                    <div class="text-muted small mb-3">
                                        Курс: <b class="text-dark">@task.RoadmapTitle</b> | Тип: @(task.TaskType == "Video" ? "🎬 Видео" : task.TaskType == "Link" ? "🔗 Ссылка" : "📝 Текст")
                                    </div>
                                    <div class="p-2 bg-light border border-light-subtle rounded small text-secondary mb-3 lh-sm" style="white-space: pre-line; font-size: 0.85rem;">
                                        @task.Content
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(task.MentorComment))
                                    {
                                        <div class="p-2 rounded border mb-3 small text-start" style="background-color: #fdf2f8; color: #9d174d; border-color: #fce7f3;">
                                            💬 <b>Фидбек преподавателя:</b> @task.MentorComment
                                        </div>
                                    }
                                </div>

                                <div class="mt-2 pt-2 border-top border-light-subtle">
                                    <div class="d-flex justify-content-between align-items-center small mb-2">
                                        <span class="text-muted">Статус:</span>
                                        <span class="fw-bold" style="color: @(task.Status == "Approved" ? "#10b981" : task.Status == "Submitted" ? "#d97706" : task.Status == "Rejected" ? "#dc2626" : "#7c3aed");">
                                            @if (task.Status == "Assigned") { <span>Назначено 📥</span> }
                                            else if (task.Status == "Submitted") { <span>На проверке ⏳</span> }
                                            else if (task.Status == "Approved") { <span>Принято ✅</span> }
                                            else if (task.Status == "Rejected") { <span>На доработку ❌</span> }
                                        </span>
                                    </div>

                                    @if (task.Status == "Assigned" || task.Status == "Rejected")
                                    {
                                        <div class="d-flex flex-column gap-2">
                                            <input type="text" placeholder="Ссылка на GitHub/ответ текстом..." @bind="studentResponsesInput[task.Id]" class="form-control form-control-sm text-sm" />
                                            <button type="button" class="btn btn-sm btn-primary text-white text-center fw-bold w-100" style="background-color: #6b21a8; border: none;" @onclick="() => SubmitTaskSolution(task.Id)">
                                                📤 Сдать работу ментору
                                            </button>
                                        </div>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(task.StudentResponse))
                                    {
                                        <div class="p-2 border rounded small text-break" style="background-color: #f0fdf4; border-color: #bbf7d0; color: #166534; font-size: 0.75rem;">
                                            <b>Ваш ответ:</b> @task.StudentResponse
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>

        <h2 class="h5 text-dark fw-bold mb-3 d-flex align-items-center gap-2">
            📂 Ваши активные учебные траектории
        </h2>

        @if (roadmaps == null || roadmaps.Count == 0)
        {
            <div class="text-center p-5 bg-white border border-light-subtle rounded-4 shadow-sm">
                <div class="display-4 mb-3">🗺️</div>
                <h3 class="h6 text-dark fw-bold mb-2">Здесь пока пусто</h3>
                <p class="text-muted small mx-auto mb-4" style="max-width: 400px;">Создайте дорожную карту вручную или сгенерируйте по любому тегу с помощью искусственного интеллекта.</p>
                <button class="btn btn-primary text-white px-4 py-2 rounded-3" @onclick="CreateNewRoadmap">Создать первую карту</button>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var rm in roadmaps)
                {
                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="card h-100 bg-white border border-light-subtle rounded-3 p-4 d-flex flex-column justify-content-between shadow-sm" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;" @onclick="() => OpenCanvas(rm.Id)">
                            <div>
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                    <h3 class="h6 m-0 text-dark fw-bold text-truncate" style="max-width: 65%; line-height: 1.3;" title="@rm.Title">@rm.Title</h3>
                                    <div class="d-flex gap-2 align-items-center">
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle py-1 px-2" style="font-size: 0.75rem;">@rm.Difficulty</span>
                                        <button type="button" class="btn p-0 border-0 text-danger fs-5 line-height-1" title="Удалить дорожную карту" @onclick="() => ConfirmDeleteRoadmap(rm.Id, rm.Title)" @onclick:stopPropagation>
                                            🗑
                                        </button>
                                    </div>
                                </div>
                                <p class="text-secondary small mb-4 lh-base text-overflow-clamp" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 2.7rem;">@rm.Description</p>
                            </div>

                            <div>
                                <div class="d-flex justify-content-between small text-secondary mb-1 fw-medium">
                                    <span>Прогресс траектории</span>
                                    <span class="text-dark fw-bold">@rm.Progress%</span>
                                </div>
                                <div class="w-100 bg-light rounded-pill mb-3" style="height: 7px; overflow: hidden;">
                                    <div style="width: @rm.Progress%; background: @(rm.Progress == 100 ? "#22c55e" : "#2563eb"); height: 100%; transition: width 0.4s ease-out;"></div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center small text-muted pt-3 border-top border-light-subtle">
                                    <span class="fw-medium text-secondary">🧩 Этапов обучения: <b class="text-dark">@rm.NodesCount</b></span>
                                    <span class="text-primary fw-semibold d-flex align-items-center gap-1">Редактор холста →</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
private List<RoadmapResponse> roadmaps = new List<RoadmapResponse>();
private GlobalDashboardAnalytics? globalAnalytics = null;
private bool isLoading = true;
private string token = "";

private List<StudentTaskDto> studentTasks = [];
private Dictionary<int, string> studentResponsesInput = new();

public class StudentTaskDto
{
public int Id { get; set; }
public string Title { get; set; } = "";
public string Content { get; set; } = "";
public string TaskType { get; set; } = "";
public string Status { get; set; } = "Assigned";
public string? StudentResponse { get; set; }
public string? MentorComment { get; set; }
public string RoadmapTitle { get; set; } = "";
public bool IsGroupTask { get; set; }
}

protected override async Task OnInitializedAsync()
{
token = await Js.InvokeAsync<string>("jiroad.loadToken");
if (string.IsNullOrWhiteSpace(token))
{
Nav.NavigateTo("/auth/login", true);
return;
}
await LoadDashboardData();
}

private HttpClient Client()
{
    // ИСПРАВЛЕНО ДЛЯ DOCKER: Автоматический роутинг сетевого адреса внутри контейнеров
    string baseAddress = Nav.BaseUri;
    if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
    {
        baseAddress = "http://127.0.0.1:8080/";
    }

    var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
    http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
    return http;
}

private async Task LoadDashboardData()
{
isLoading = true;
StateHasChanged();
try
{
using var http = Client();
var response = await http.GetFromJsonAsync<DashboardDataResponse>("/api/roadmap/list");
if (response != null)
{
roadmaps = response.Roadmaps ?? new List<RoadmapResponse>();
globalAnalytics = response.Analytics;
}

// Загружаем список персональных и групповых заданий текущего студента
studentTasks = await http.GetFromJsonAsync<List<StudentTaskDto>>("/api/roadmap/student/tasks") ?? [];

// ИСПРАВЛЕНИЕ ОШИБКИ KeyNotFoundException: Инициализируем словарь инпутов для двухсторонней привязки
foreach (var task in studentTasks)
{
if (!studentResponsesInput.ContainsKey(task.Id))
{
studentResponsesInput[task.Id] = "";
}
}
}
catch (Exception ex)
{
Console.WriteLine($"[ОШИБКА ДАШБОРДА]: {ex.Message}");
}
finally
{
isLoading = false;
StateHasChanged();
}
}

private async Task SubmitTaskSolution(int taskId)
{
studentResponsesInput.TryGetValue(taskId, out var text);
if (string.IsNullOrWhiteSpace(text)) return;

try
{
using var http = Client();

var payload = new { TaskId = taskId, Response = text.Trim() };
var response = await http.PostAsJsonAsync("/api/roadmap/student/tasks/submit", payload);
if (response.IsSuccessStatusCode)
{
studentResponsesInput[taskId] = "";
await LoadDashboardData();
await Js.InvokeVoidAsync("alert", "🚀 Ваша работа успешно отправлена ментору на проверку!");
}
}
catch (Exception ex)
{
Console.WriteLine($"[ОШИБКА ОТПРАВКИ]: {ex.Message}");
}
}

private async Task ConfirmDeleteRoadmap(int id, string title)
{
bool confirmed = await Js.InvokeAsync<bool>("confirm", $"Вы уверены, что хотите полностью удалить дорожную карту \"{title}\"? Это действие сотрет карту из базы данных и его нельзя будет отменить.");
if (!confirmed) return;

try
{
using var http = Client();

var response = await http.DeleteAsync($"/api/roadmap/{id}");
if (response.IsSuccessStatusCode)
{
await LoadDashboardData();
}
else
{
Console.WriteLine($"[ОШИБКА УДАЛЕНИЯ]: {response.StatusCode}");
}
}
catch (Exception ex)
{
Console.WriteLine($"[ОШИБКА HTTP ПРИ УДАЛЕНИИ]: {ex.Message}");
}
}

private void CreateNewRoadmap() => Nav.NavigateTo("/roadmaps/new");
private void NavigateToAiGenerator() => Nav.NavigateTo("/ai-generator");
private void OpenCanvas(int id) => Nav.NavigateTo($"/canvas/{id}");
}