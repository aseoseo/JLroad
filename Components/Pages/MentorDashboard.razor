@page "/mentor/dashboard"
@layout WorkspaceLayout
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using JIroad.Api
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Панель Преподавателя | JIroad</PageTitle>

<div class="container-fluid px-2 px-md-4 my-4" style="max-width: 1400px; font-family: system-ui, -apple-system, sans-serif;">
    
    <header class="p-4 mb-4 bg-white border rounded-4 shadow-sm d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
        <div>
            <h1 class="m-0 text-dark fw-bold fs-3">👨‍🏫 Панель Мониторинга и Групп</h1>
            <p class="m-0 text-muted mt-2 small">Управляйте группами, создавайте общие курсы и отслеживайте выполнение персональных заданий.</p>
        </div>
        
        <div class="d-flex flex-wrap align-items-center gap-2 justify-content-start justify-content-xl-end">
            <button class="btn btn-sm btn-outline-danger fw-semibold px-3 py-2 rounded-3 style-help-btn" style="background-color: #fdf2f8 !important; color: #9d174d !important; border-color: #fce7f3 !important;" @onclick='() => Nav.NavigateTo("/help")'>
                📖 База знаний (Справка)
            </button>

            <div class="d-flex gap-2 p-2 bg-light border border-secondary-subtle rounded-3 w-100 w-sm-auto" style="max-width: 360px;">
                <input type="email" @bind="studentEmailInput" placeholder="Email ученика для привязки..." class="form-control form-control-sm text-sm" />
                <button type="button" class="btn btn-sm btn-primary text-white fw-bold px-3 border-0" @onclick="AddStudent">
                    Привязать
                </button>
            </div>
        </div>
    </header>

    <div class="d-flex gap-2 mb-4 border-bottom pb-2">
        <button type="button" class="btn fw-bold px-3 py-2 rounded-3 text-sm @(activeTab == "students" ? "btn-primary text-white border-0 shadow" : "btn-light border text-secondary")" @onclick='() => activeTab = "students"'>
            👥 По ученикам (Индивидуально)
        </button>
        <button type="button" class="btn fw-bold px-3 py-2 rounded-3 text-sm @(activeTab == "groups" ? "btn-primary text-white border-0 shadow" : "btn-light border text-secondary")" @onclick='async () => { activeTab = "groups"; await LoadMentorMasterRoadmaps(); }'>
            📊 Групповой трекинг (По картам)
        </button>
    </div>

    @if (activeTab == "students")
    {
        <div class="row g-4">
            <aside class="col-12 col-lg-4 col-xl-3">
                <div class="card p-4 bg-white border border-light-subtle rounded-3 shadow-sm h-100">
                    <h3 class="h6 text-dark fw-bold mb-3">👥 Ваши учащиеся (@students.Count)</h3>
                    <div class="d-flex flex-column gap-2 overflow-y-auto" style="max-height: 500px;">
                        @foreach (var s in students)
                        {
                            <div class="p-3 border rounded-3 text-start shadow-sm" style="cursor: pointer; transition: background 0.2s, border-color 0.2s; border-color: @(selectedStudentId == s.Id ? "#2563eb" : "#e2e8f0") !important; background-color: @(selectedStudentId == s.Id ? "#eff6ff" : "#ffffff");" @onclick="() => SelectStudent(s.Id, s.UserName)">
                                <div class="fw-bold text-dark small text-truncate">@s.UserName</div>
                                <div class="text-muted small text-truncate" style="font-size: 0.8rem;">@s.Email</div>
                            </div>
                        }
                    </div>
                </div>
            </aside>

            <main class="col-12 col-lg-8 col-xl-9">
                <div class="card p-4 bg-white border border-light-subtle rounded-3 shadow-sm h-100 text-start">
                    @if (selectedStudentId == 0)
                    {
                        <p class="text-muted text-center py-5 my-auto">Выберите учащегося слева для управления его треками.</p>
                    }
                    else
                    {
                        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4 pb-2 border-bottom">
                            <h3 class="h5 m-0 fw-bold text-dark">Учебные планы: @selectedStudentName</h3>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-success fw-bold py-2 rounded-3" style="background-color: #f0fdf4; border-color: #bbf7d0; color: #166534;" @onclick="() => { showManualForm = !showManualForm; showAiForm = false; }">➕ Назначить вручную</button>
                                <button type="button" class="btn btn-sm btn-outline-primary fw-bold py-2 rounded-3" style="background-color: #faf5ff; border-color: #e9d5ff; color: #6b21a8;" @onclick="() => { showAiForm = !showAiForm; showManualForm = false; }">🧠 Через ИИ</button>
                            </div>
                        </div>

                        @if (showManualForm)
                        {
                            <div class="p-3 bg-light border rounded-3 mb-4">
                                <input type="text" @bind="newTitle" placeholder="Название карты" class="form-control form-control-sm mb-2" />
                                <button type="button" class="btn btn-sm btn-success text-white px-3" @onclick="CreateManualRoadmapForStudent">Сохранить</button>
                            </div>
                        }

                        @if (showAiForm)
                        {
                            <div class="p-3 border rounded-3 mb-4" style="background-color: #faf5ff; border-color: #f3e8ff;">
                                <input type="text" @bind="aiGoal" placeholder="Чему должен обучиться студент?" class="form-control form-control-sm mb-2" />
                                <button type="button" class="btn btn-sm btn-primary text-white px-3" style="background-color: #a855f7; border: none;" @onclick="GenerateAiRoadmapForStudent">Сгенерировать</button>
                            </div>
                        }

                        <div class="d-flex flex-column gap-3">
                            @foreach (var rm in studentRoadmaps)
                            {
                                <div class="p-3 border border-light-subtle rounded-3 bg-light shadow-sm">
                                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-3">
                                        <div>
                                            <h4 class="h6 m-0 fw-bold text-dark">@rm.Title</h4>
                                            <span class="small fw-bold text-primary" style="font-size: 0.85rem;">Progress: @rm.Progress%</span>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="button" class="btn btn-sm btn-primary text-white fw-bold px-3 py-1.5" style="background-color: #a855f7; border: none;" @onclick="() => PrepareTaskModalIndividual(selectedStudentId, rm.Id)">➕ Выдать лично</button>
                                            <button type="button" class="btn btn-sm btn-primary text-white fw-bold px-3 py-1.5" @onclick='() => Nav.NavigateTo($"/canvas/{rm.Id}")'>Открыть холст</button>
                                        </div>
                                    </div>

                                    <div class="bg-white border rounded-3 p-3 mt-2" style="border-color: #f3e8ff !important;">
                                        <div class="small fw-bold text-purple border-bottom pb-1 mb-2" style="color: #6b21a8;">
                                            📌 Задания и решения по данной карте:
                                        </div>
                                        @if (studentTasksCache.TryGetValue(rm.Id, out var tasks) && tasks.Any())
                                        {
                                            <div class="d-flex flex-column gap-2">
                                                @foreach (var t in tasks)
                                                {
                                                    <div class="p-3 border rounded-3 small d-flex flex-column gap-2" style="background-color: #fef8ff; border-color: #f3e8ff !important;">
                                                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                                            <span class="fw-medium text-dark"><b>@t.Title</b> (@(t.TaskType == "Video" ? "🎬 Видео" : t.TaskType == "Link" ? "🔗 Ссылка" : "📝 Текст")) @(t.IsGroupTask ? "👥 [Группа]" : "👤 [Личное]")</span>
                                                            @if (t.Status == "Assigned") { <span class="badge bg-purple text-white p-1" style="background-color: #6b21a8;">Выдано</span> }
                                                            else if (t.Status == "Submitted") { <span class="badge bg-warning text-dark p-1">На проверке ⏳</span> }
                                                            else if (t.Status == "Approved") { <span class="badge bg-success text-white p-1">Принято ✅</span> }
                                                            else if (t.Status == "Rejected") { <span class="badge bg-danger text-white p-1">На доработку ❌</span> }
                                                        </div>

                                                        @if (!string.IsNullOrWhiteSpace(t.Content))
                                                        {
                                                            <div class="text-secondary p-2 bg-light rounded" style="font-size: 0.75rem;">Условие: @t.Content</div>
                                                        }

                                                        @if (!string.IsNullOrWhiteSpace(t.StudentResponse))
                                                        {
                                                            <div class="p-2 bg-white border border-secondary-subtle border-dashed rounded text-dark text-break small">
                                                                <b>Ответ учащегося:</b> <br/>
                                                                @if (t.StudentResponse.StartsWith("http")) { <a href="@t.StudentResponse" target="_blank" class="text-primary text-decoration-underline">@t.StudentResponse</a> }
                                                                else { <span>@t.StudentResponse</span> }
                                                            </div>
                                                        }

                                                        @if (t.Status == "Submitted")
                                                        {
                                                            <div class="mt-1 d-flex flex-column flex-sm-row gap-2 bg-white p-2 border rounded">
                                                                <input type="text" placeholder="Комментарий / замечание..." @bind="mentorCommentsInput[t.Id]" class="form-control form-control-sm text-xs" style="font-size: 0.75rem;" />
                                                                <div class="d-flex gap-2">
                                                                    <button type="button" class="btn btn-sm btn-danger text-white px-3" @onclick='() => ReviewTask(t.Id, "Rejected", t.IsGroupTask)'>Вернуть</button>
                                                                    <button type="button" class="btn btn-sm btn-success text-white px-3" @onclick='() => ReviewTask(t.Id, "Approved", t.IsGroupTask)'>Принять</button>
                                                                </div>
                                                            </div>
                                                        }
                                                        else if (!string.IsNullOrWhiteSpace(t.MentorComment))
                                                        {
                                                            <div class="text-secondary small fst-italic" style="color: #a21caf !important;">💬 Ваш фидбек: @t.MentorComment</div>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small fst-italic">Заданий пока нет.</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        @if (showTaskForm)
                        {
                            <div class="mt-4 p-3 border rounded-3 d-flex flex-column gap-2" style="background-color: #faf5ff; border-color: #e9d5ff;">
                                <h4 class="h6 text-purple fw-bold m-0" style="color: #6b21a8;">🎯 Назначить индивидуальную работу</h4>
                                
                                <div class="row g-2">
                                    <div class="col-12 col-sm-6">
                                        <label class="form-label small fw-bold text-dark mb-1">Тип контента:</label>
                                        <select @bind="taskType" class="form-select form-select-sm">
                                            <option value="Video">🎬 Видео-разбор (Ссылка)</option>
                                            <option value="Link">🔗 Ссылка на проект (GitHub/Figma)</option>
                                            <option value="Text">📝 Текстовая задача</option>
                                        </select>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <label class="form-label small fw-bold text-dark mb-1">Название задания:</label>
                                        <input type="text" @bind="taskTitle" placeholder="Например: Лабораторная №1" class="form-control form-control-sm" />
                                    </div>
                                </div>

                                <div class="mt-1">
                                    <label class="form-label small fw-bold text-dark mb-1">Содержимое задания (Текст или URL):</label>
                                    <textarea @bind="taskContent" placeholder="Вставьте ссылку на материал или распишите требования..." class="form-control form-control-sm" style="height: 70px;"></textarea>
                                </div>

                                <div class="d-flex justify-content-end gap-2 mt-2">
                                    <button type="button" class="btn btn-sm btn-light border px-3" @onclick="() => showTaskForm = false">Отмена</button>
                                    <button type="button" class="btn btn-sm btn-primary text-white fw-bold px-3" style="background-color: #a855f7; border: none;" @onclick="SendPersonalTask">Отправить студенту</button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </main>
        </div>
    }
    else if (activeTab == "groups")
    {
        <div class="row g-4">
            <aside class="col-12 col-lg-4 col-xl-3">
                <div class="card p-4 bg-white border border-light-subtle rounded-3 shadow-sm h-100">
                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center border-bottom pb-2 mb-3 gap-2 text-start">
                        <h3 class="h6 m-0 fw-bold text-dark">📋 Общие курсы</h3>
                        <div class="d-flex gap-1">
                            <button type="button" class="btn btn-sm btn-primary text-white px-2 py-1 small" @onclick='() => Nav.NavigateTo($"/canvas/{selectedMasterRoadmapId}")' disabled="@(selectedMasterRoadmapId == 0)">
                                ✏️ Холст
                            </button>
                            <button type="button" class="btn btn-sm btn-success text-white px-2 py-1 small" @onclick="() => showCreateMasterForm = !showCreateMasterForm">
                                @(showCreateMasterForm ? "Закрыть" : "＋ Создать")
                            </button>
                        </div>
                    </div>

                    @if (showCreateMasterForm)
                    {
                        <div class="p-3 border rounded-3 mb-3 text-start" style="background-color: #f0fdf4; border-color: #bbf7d0;">
                            <strong class="small text-success d-block mb-1">Новый общий курс:</strong>
                            <input type="text" @bind="masterTitle" placeholder="Название (например: С# с нуля)" class="form-control form-control-sm mb-2" />
                            <input type="text" @bind="masterDescription" placeholder="Краткое описание курса" class="form-control form-control-sm mb-2" />
                            <button type="button" class="btn btn-sm btn-success text-white w-100 fw-bold" @onclick="CreateMasterRoadmap">
                                Создать мастер-курс
                            </button>
                        </div>
                    }

                    <div class="d-flex flex-column gap-2 overflow-y-auto" style="max-height: 500px;">
                        @foreach (var rm in mentorMasterRoadmaps)
                        {
                            <div class="p-3 border rounded-3 text-start shadow-sm" style="cursor: pointer; transition: background 0.2s, border-color 0.2s; border-color: @(selectedMasterRoadmapId == rm.Id ? "#2563eb" : "#e2e8f0") !important; background-color: @(selectedMasterRoadmapId == rm.Id ? "#f0fdf4" : "#ffffff");" @onclick="() => SelectMasterRoadmap(rm.Id)">
                                <div class="fw-bold text-dark small text-truncate">🎯 @rm.Title</div>
                                <div class="text-muted small" style="font-size: 0.8rem;">ID на сервере: #@rm.Id</div>
                            </div>
                        }
                    </div>
                </div>
            </aside>

            <main class="col-12 col-lg-8 col-xl-9">
                <div class="card p-4 bg-white border border-light-subtle rounded-3 shadow-sm h-100 text-start">
                    @if (selectedMasterRoadmapId == 0)
                    {
                        <div class="text-center py-5 my-auto text-muted">
                            <h4>Выберите созданный общий курс слева, чтобы открыть ведомость успеваемости студентов</h4>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-4 pb-2 border-bottom">
                            <h3 class="h5 m-0 fw-bold text-dark">📊 Студенты на курсе</h3>
                            <button type="button" class="btn btn-sm btn-primary text-white fw-bold px-3 py-2" @onclick="() => { showGroupTaskForm = !showGroupTaskForm; showTaskForm = false; }">
                                📢 Выдать задание ВСЕЙ группе
                            </button>
                        </div>

                        <div class="p-3 bg-light border border-secondary-subtle rounded-3 mb-4 d-flex flex-column flex-sm-row align-items-sm-center gap-2">
                            <span class="fw-bold small text-secondary">👥 Добавить студента в группу курса:</span>
                            <select @bind="studentToEnrollId" class="form-select form-select-sm w-100 w-sm-auto" style="max-width: 250px;">
                                <option value="0">-- Выберите из списка --</option>
                                @foreach (var s in students)
                                {
                                    <option value="@s.Id">@s.UserName (@s.Email)</option>
                                }
                            </select>
                            <button type="button" class="btn btn-sm btn-success text-white fw-bold px-3 py-1.5 ms-sm-auto" @onclick="EnrollStudentToGroup">
                                Добавить в группу
                            </button>
                        </div>

                        @if (showGroupTaskForm)
                        {
                            <div class="p-3 border rounded-3 mb-4 d-flex flex-column gap-2" style="background-color: #eff6ff; border-color: #bfdbfe;">
                                <h4 class="h6 text-primary fw-bold m-0" style="color: #1e40af;">📢 Создать задание для всех студентов курса</h4>
                                <div class="row g-2">
                                    <div class="col-12 col-sm-6">
                                        <label class="form-label small fw-bold text-dark mb-1">Тип задания:</label>
                                        <select @bind="groupTaskType" class="form-select form-select-sm">
                                            <option value="Video">🎬 Видео-разбор</option>
                                            <option value="Link">🔗 Репозиторий / Ссылка</option>
                                            <option value="Text">📝 Текстовое задание</option>
                                        </select>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <label class="form-label small fw-bold text-dark mb-1">Название задания:</label>
                                        <input type="text" @bind="groupTaskTitle" placeholder="Например: Лабораторная работа для группы" class="form-control form-control-sm" />
                                    </div>
                                </div>
                                <div class="mt-1">
                                    <label class="form-label small fw-bold text-dark mb-1">Описание или ссылка на требования:</label>
                                    <textarea @bind="groupTaskContent" placeholder="Опишите требования к выполнению..." class="form-control form-control-sm" style="height: 70px;"></textarea>
                                </div>
                                <div class="d-flex justify-content-end gap-2 mt-2">
                                    <button type="button" class="btn btn-sm btn-light border px-3" @onclick="() => showGroupTaskForm = false">Отмена</button>
                                    <button type="button" class="btn btn-sm btn-primary text-white fw-bold px-3" @onclick="SendGroupTask">Опубликовать</button>
                                </div>
                            </div>
                        }

                        @if (!groupProgressList.Any())
                        {
                            <p class="text-muted small fst-italic">В этой группе пока нет студентов. Добавьте участников с помощью панели выше.</p>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-3">
                                @foreach (var participant in groupProgressList)
                                {
                                    <div class="p-3 border border-light-subtle rounded-3 bg-light shadow-sm">
                                        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2 mb-2">
                                            <div>
                                                <strong class="text-dark small">👤 @participant.StudentName</strong>
                                                <span class="text-secondary small ms-sm-2" style="font-size: 0.8rem;">@participant.StudentEmail</span>
                                            </div>
                                            
                                            <div class="d-flex gap-2">
                                                <button type="button" class="btn btn-sm btn-success text-white fw-bold" @onclick='() => Nav.NavigateTo($"/canvas/{participant.StudentRoadmapId}")'>
                                                    🗺️ Холст
                                                </button>
                                                <button type="button" class="btn btn-sm btn-primary text-white fw-bold" style="background-color: #a855f7; border: none;" @onclick="() => PrepareTaskModalGroup(participant.StudentId, participant.StudentRoadmapId)">
                                                    ➕ Задание
                                                </button>
                                            </div>
                                        </div>

                                        <div class="d-flex align-items-center gap-2 mb-3">
                                            <div class="w-100 bg-secondary-subtle rounded" style="height: 8px; overflow: hidden; background-color: #e2e8f0;">
                                                <div style="width: @participant.Progress%; background-color: #10b981; height: 100%;"></div>
                                            </div>
                                            <span class="small fw-bold text-dark text-nowrap">@participant.Progress%</span>
                                        </div>

                                        <div class="bg-white border rounded-3 p-3">
                                            <div class="small fw-bold text-purple border-bottom pb-1 mb-2" style="color: #6b21a8;">
                                                📌 Назначенные задания и решения:
                                            </div>

                                            @if (studentTasksCache.TryGetValue(participant.StudentRoadmapId, out var tasks) && tasks.Any())
                                            {
                                                <div class="d-flex flex-column gap-2">
                                                    @foreach (var t in tasks)
                                                    {
                                                        <div class="p-3 border rounded-3 small d-flex flex-column gap-2" style="background-color: #fef8ff; border-color: #f3e8ff !important;">
                                                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                                                <span class="fw-medium text-dark"><b>@t.Title</b> (@(t.TaskType == "Video" ? "🎬 Видео" : t.TaskType == "Link" ? "🔗 Ссылка" : "📝 Текст")) @(t.IsGroupTask ? "👥 [Группа]" : "👤 [Личное]")</span>
                                                                @if (t.Status == "Assigned") { <span class="badge bg-purple text-white p-1" style="background-color: #6b21a8;">Выдано</span> }
                                                                else if (t.Status == "Submitted") { <span class="badge bg-warning text-dark p-1">На проверке ⏳</span> }
                                                                else if (t.Status == "Approved") { <span class="badge bg-success text-white p-1">Принято ✅</span> }
                                                                else if (t.Status == "Rejected") { <span class="badge bg-danger text-white p-1">На доработку ❌</span> }
                                                            </div>

                                                            @if (!string.IsNullOrWhiteSpace(t.Content))
                                                            {
                                                                <div class="text-secondary p-2 bg-light rounded" style="font-size: 0.75rem;">Условие: @t.Content</div>
                                                            }

                                                            @if (!string.IsNullOrWhiteSpace(t.StudentResponse))
                                                            {
                                                                <div class="p-2 bg-white border border-secondary-subtle border-dashed rounded text-dark text-break small">
                                                                                                                                    <b>Ответ учащегося:</b> <br/>
                                                                    @if (t.StudentResponse.StartsWith("http")) { <a href="@t.StudentResponse" target="_blank" class="text-primary text-decoration-underline">@t.StudentResponse</a> }
                                                                    else { <span>@t.StudentResponse</span> }
                                                                </div>
                                                            }

                                                            @if (t.Status == "Submitted")
                                                            {
                                                                <div class="mt-1 d-flex flex-column flex-sm-row gap-2 bg-white p-2 border rounded">
                                                                    <input type="text" placeholder="Комментарий / замечание..." @bind="mentorCommentsInput[t.Id]" class="form-control form-control-sm text-xs" style="font-size: 0.75rem;" />
                                                                    <div class="d-flex gap-2">
                                                                        <button type="button" class="btn btn-sm btn-danger text-white px-3" @onclick='() => ReviewTask(t.Id, "Rejected", t.IsGroupTask)'>Вернуть</button>
                                                                        <button type="button" class="btn btn-sm btn-success text-white px-3" @onclick='() => ReviewTask(t.Id, "Approved", t.IsGroupTask)'>Принять</button>
                                                                    </div>
                                                                </div>
                                                            }
                                                            else if (!string.IsNullOrWhiteSpace(t.MentorComment))
                                                            {
                                                                <div class="text-secondary small fst-italic" style="color: #a21caf !important;">💬 Ваш фидбек: @t.MentorComment</div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted small fst-italic">Заданий пока нет.</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @if (showTaskForm)
                        {
                            <div class="mt-4 p-3 border rounded-3 d-flex flex-column gap-2" style="background-color: #faf5ff; border-color: #e9d5ff;">
                                <h4 class="h6 text-purple fw-bold m-0" style="color: #6b21a8;">🎯 Назначить индивидуальную работу</h4>
                                
                                <div class="row g-2">
                                    <div class="col-12 col-sm-6">
                                        <label class="form-label small fw-bold text-dark mb-1">Тип контента:</label>
                                        <select @bind="taskType" class="form-select form-select-sm">
                                            <option value="Video">🎬 Видео-разбор (Ссылка)</option>
                                            <option value="Link">🔗 Ссылка на проект (GitHub/Figma)</option>
                                            <option value="Text">📝 Текстовая задача</option>
                                        </select>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <label class="form-label small fw-bold text-dark mb-1">Название задания:</label>
                                        <input type="text" @bind="taskTitle" placeholder="Например: Лабораторная №1" class="form-control form-control-sm" />
                                    </div>
                                </div>

                                <div class="mt-1">
                                    <label class="form-label small fw-bold text-dark mb-1">Содержимое задания (Текст или URL):</label>
                                    <textarea @bind="taskContent" placeholder="Вставьте ссылку на материал или распишите требования..." class="form-control form-control-sm" style="height: 70px;"></textarea>
                                </div>

                                <div class="d-flex justify-content-end gap-2 mt-2">
                                    <button type="button" class="btn btn-sm btn-light border px-3" @onclick="() => showTaskForm = false">Отмена</button>
                                    <button type="button" class="btn btn-sm btn-primary text-white fw-bold px-3" style="background-color: #a855f7; border: none;" @onclick="SendPersonalTask">Отправить студенту</button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </main>
        </div>
    }
</div>

@code {
    private string token = "";
    private string studentEmailInput = "";
    private string activeTab = "students"; 
    
    private int selectedStudentId = 0;
    private string selectedStudentName = "";
    
    private bool showManualForm = false;
    private bool showAiForm = false;
    private bool showCreateMasterForm = false; 
    private bool showGroupTaskForm = false;
    private bool showTaskForm = false; 

    private string newTitle = "";
    private string newDescription = "";
    private string newCategory = "General";
    private string aiGoal = "";
    private string aiTimeline = "";

    private string masterTitle = "";
    private string masterDescription = "";

    private int selectedMasterRoadmapId = 0;
    private int studentToEnrollId = 0;
    private int targetStudentIdForTask = 0;
    private string taskType = "Video";
    private string taskTitle = "";
    private string taskContent = "";
    private string groupTaskType = "Text";
    private string groupTaskTitle = "";
    private string groupTaskContent = "";
    private Dictionary<int, string> mentorCommentsInput = new();
    private List<StudentDto> students = [];
    private List<RoadmapResponse> studentRoadmaps = [];
    private List<RoadmapResponse> mentorMasterRoadmaps = [];
    private List<GroupProgressDto> groupProgressList = [];
    private Dictionary<int, List<TaskDto>> studentTasksCache = new();

    public class StudentDto { public int Id { get; set; } public string UserName { get; set; } = ""; public string Email { get; set; } = ""; }
    public class GroupProgressDto { public int StudentId { get; set; } public int StudentRoadmapId { get; set; } public string StudentName { get; set; } = ""; public string StudentEmail { get; set; } = ""; public int Progress { get; set; } }
    
    public class TaskDto { 
        public int Id { get; set; } 
        public string TaskType { get; set; } = "";
        public string Title { get; set; } = ""; 
        public string Content { get; set; } = "";
        public string Status { get; set; } = "Assigned";
        public string? StudentResponse { get; set; }
        public string? MentorComment { get; set; }
        public bool IsGroupTask { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        token = await Js.InvokeAsync<string>("jiroad.loadToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/auth/login", true);
            return;
        }
        await LoadStudentsList();
    }

    private HttpClient Client()
    {
        // ИСПРАВЛЕНО: Умное переключение BaseAddress при запуске внутри Docker-контейнера
        string baseAddress = Nav.BaseUri;
        if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
        {
            baseAddress = "http://127.0.0.1:8080/";
        }

        var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
        http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return http;
    }

    private async Task LoadStudentsList()
    {
        try {
            using var http = Client();
            students = await http.GetFromJsonAsync<List<StudentDto>>("/api/roadmap/mentor/students/list") ?? [];
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task LoadMentorMasterRoadmaps()
    {
        try {
            using var http = Client();
            mentorMasterRoadmaps = await http.GetFromJsonAsync<List<RoadmapResponse>>("/api/roadmap/mentor/master-roadmaps") ?? [];
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task CreateMasterRoadmap()
    {
        if (string.IsNullOrWhiteSpace(masterTitle)) return;
        try {
            using var http = Client();
            var payload = new { Title = masterTitle.Trim(), Description = masterDescription.Trim(), Category = "Курс", Difficulty = "Intermediate", Tags = "master", IsPublic = false };
            var response = await http.PostAsJsonAsync("/api/roadmap/create", payload);
            if (response.IsSuccessStatusCode)
            {
                masterTitle = "";
                masterDescription = ""; showCreateMasterForm = false;
                await LoadMentorMasterRoadmaps();
                await Js.InvokeVoidAsync("alert", "🚀 Общий курс (Группа) успешно создан!");
            }
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task EnrollStudentToGroup()
    {
        if (selectedMasterRoadmapId == 0 || studentToEnrollId == 0) return;
        try {
            using var http = Client();
            var response = await http.PostAsJsonAsync($"/api/roadmap/mentor/master-roadmaps/{selectedMasterRoadmapId}/enroll", new { studentId = studentToEnrollId });
            if (response.IsSuccessStatusCode)
            {
                studentToEnrollId = 0;
                await SelectMasterRoadmap(selectedMasterRoadmapId);
                await Js.InvokeVoidAsync("alert", "🎯 Студент успешно зачислен в группу этого курса!");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                await Js.InvokeVoidAsync("alert", "⚠️ Данный студент уже состоит в этой группе!");
            }
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task SelectMasterRoadmap(int id)
    {
        selectedMasterRoadmapId = id;
        showTaskForm = false; showGroupTaskForm = false;
        studentTasksCache.Clear(); mentorCommentsInput.Clear();
        try {
            using var http = Client();
            groupProgressList = await http.GetFromJsonAsync<List<GroupProgressDto>>($"/api/roadmap/mentor/master-roadmaps/{id}/progress") ?? [];
            foreach (var p in groupProgressList)
            {
                var tasks = await http.GetFromJsonAsync<List<TaskDto>>($"/api/roadmap/mentor/students/personal-tasks/{p.StudentRoadmapId}") ?? [];
                studentTasksCache[p.StudentRoadmapId] = tasks;
                
                foreach (var t in tasks)
                {
                    if (!mentorCommentsInput.ContainsKey(t.Id))
                        mentorCommentsInput[t.Id] = "";
                }
            }
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private void PrepareTaskModalGroup(int studentId, int roadmapId)
    {
        targetStudentIdForTask = studentId;
        selectedMasterRoadmapId = roadmapId; 
        taskTitle = ""; taskContent = "";
        showTaskForm = true; showGroupTaskForm = false;
    }

    private void PrepareTaskModalIndividual(int studentId, int roadmapId)
    {
        targetStudentIdForTask = studentId;
        selectedMasterRoadmapId = roadmapId; 
        taskTitle = ""; taskContent = "";
        showTaskForm = true;
    }

    private async Task SendPersonalTask()
    {
        if (string.IsNullOrWhiteSpace(taskTitle) || string.IsNullOrWhiteSpace(taskContent)) return;
        try {
            using var http = Client();
            var payload = new { StudentId = targetStudentIdForTask, RoadmapId = selectedMasterRoadmapId, TaskType = taskType, Title = taskTitle.Trim(), Content = taskContent.Trim() };
            var response = await http.PostAsJsonAsync("/api/roadmap/mentor/tasks/assign", payload);
            if (response.IsSuccessStatusCode)
            {
                showTaskForm = false;
                if (activeTab == "groups") {
                    await SelectMasterRoadmap(selectedMasterRoadmapId); 
                } else {
                    await RefreshStudentRoadmaps();
                }
                await Js.InvokeVoidAsync("alert", "🎯 Индивидуальное задание успешно отправлено!");
            }
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task SendGroupTask()
    {
        if (string.IsNullOrWhiteSpace(groupTaskTitle) || string.IsNullOrWhiteSpace(groupTaskContent)) return;
        try {
            using var http = Client();
            var payload = new { RoadmapId = selectedMasterRoadmapId, TaskType = groupTaskType, Title = groupTaskTitle.Trim(), Content = groupTaskContent.Trim() };
            var response = await http.PostAsJsonAsync("/api/roadmap/mentor/tasks/assign-group", payload);
            if (response.IsSuccessStatusCode)
            {
                showGroupTaskForm = false;
                groupTaskTitle = ""; groupTaskContent = "";
                await SelectMasterRoadmap(selectedMasterRoadmapId);
                await Js.InvokeVoidAsync("alert", "📢 Общее задание опубликовано для всей группы!");
            }
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task ReviewTask(int taskId, string status, bool isGroupTask)
    {
        mentorCommentsInput.TryGetValue(taskId, out var comment);
        try {
            using var http = Client();
            var payload = new { TaskId = taskId, Status = status, Comment = comment ?? "", IsGroupTask = isGroupTask };
            var response = await http.PostAsJsonAsync("/api/roadmap/mentor/tasks/review", payload);
            if (response.IsSuccessStatusCode)
            {
                if (activeTab == "groups") {
                    await SelectMasterRoadmap(selectedMasterRoadmapId);
                } else {
                    await RefreshStudentRoadmaps();
                }
                await Js.InvokeVoidAsync("alert", "Вердикт проверки успешно сохранен!");
            }
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task SelectStudent(int id, string name)
    {
        selectedStudentId = id;
        selectedStudentName = name;
        showManualForm = false; showAiForm = false; showTaskForm = false;
        await RefreshStudentRoadmaps();
    }

    private async Task RefreshStudentRoadmaps()
    {
        studentTasksCache.Clear();
        mentorCommentsInput.Clear();
        try {
            using var http = Client();
            studentRoadmaps = await http.GetFromJsonAsync<List<RoadmapResponse>>($"/api/roadmap/mentor/students/{selectedStudentId}/roadmaps") ?? [];
            
            foreach (var rm in studentRoadmaps)
            {
                var tasks = await http.GetFromJsonAsync<List<TaskDto>>($"/api/roadmap/mentor/students/personal-tasks/{rm.Id}") ?? [];
                studentTasksCache[rm.Id] = tasks;
                
                foreach (var t in tasks)
                {
                    if (!mentorCommentsInput.ContainsKey(t.Id))
                        mentorCommentsInput[t.Id] = "";
                }
            }
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task CreateManualRoadmapForStudent()
    {
        if (string.IsNullOrWhiteSpace(newTitle) || selectedStudentId == 0) return;
        try {
            using var http = Client();
            var payload = new { Title = newTitle.Trim(), Description = newDescription.Trim(), Category = newCategory.Trim(), Difficulty = "Beginner", Tags = "assigned", IsPublic = false };
            var response = await http.PostAsJsonAsync($"/api/roadmap/mentor/students/{selectedStudentId}/create-manual", payload);
            if (response.IsSuccessStatusCode)
            {
                newTitle = "";
                newDescription = ""; showManualForm = false;
                await RefreshStudentRoadmaps();
            }
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task GenerateAiRoadmapForStudent()
    {
        if (string.IsNullOrWhiteSpace(aiGoal) || selectedStudentId == 0) return;
        try {
            using var http = Client();
            var payload = new { Goal = aiGoal.Trim(), Timeline = aiTimeline.Trim(), CurrentLevel = "Beginner", Category = "Программирование" };
            var response = await http.PostAsJsonAsync($"/api/roadmap/mentor/students/{selectedStudentId}/create-ai", payload);
            if (response.IsSuccessStatusCode)
            {
                aiGoal = "";
                aiTimeline = ""; showAiForm = false;
                await RefreshStudentRoadmaps();
            }
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task AddStudent()
    {
        if (string.IsNullOrWhiteSpace(studentEmailInput)) return;
        try {
            using var http = Client();
            var response = await http.PostAsJsonAsync("/api/roadmap/mentor/students/add", new { email = studentEmailInput.Trim() });
            if (response.IsSuccessStatusCode)
            {
                studentEmailInput = "";
                await LoadStudentsList();
                await Js.InvokeVoidAsync("alert", "🚀 Ученик успешно привязан!");
            }
        } catch (Exception ex) { Console.WriteLine(ex.Message); }
    }
}