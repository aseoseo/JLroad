@page "/roadmaps/new"
@layout WorkspaceLayout
@using System.Net.Http.Headers
@using System.Net.Http.Json
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Создание Roadmap | JIroad</PageTitle>

<div class="container-fluid px-2 px-md-4 my-4 text-start" style="max-width: 800px; font-family: system-ui, sans-serif;">
    
    <button type="button" @onclick="GoBack" class="btn btn-sm btn-link text-secondary text-decoration-none d-inline-flex align-items-center gap-2 p-0 mb-4" style="box-shadow: none;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
        </svg>
        Назад
    </button>

    <h1 class="h3 text-dark fw-bold mb-4">Создание новой дорожной карты</h1>

    <section class="card p-4 border border-light-subtle rounded-4 shadow-sm bg-white">
        <form @onsubmit="CreateRoadmap" @onsubmit:preventDefault="true">
            <div class="row g-3" style="max-width: 550px;">
                
                <div class="col-12">
                    <label class="form-label small fw-semibold text-secondary mb-1">Название новой карты:</label>
                    <input type="text" class="form-control form-control-lg text-sm" style="font-size: 0.95rem; border-radius: 8px;" placeholder="Введите название..." @bind="title" required />
                </div>

                <div class="col-12">
                    <label class="form-label small fw-semibold text-secondary mb-1">Краткое описание:</label>
                    <input type="text" class="form-control form-control-lg text-sm" style="font-size: 0.95rem; border-radius: 8px;" placeholder="О чем этот трек обучения?" @bind="description"/>
                </div>

                <div class="col-12">
                    <label class="form-label small fw-semibold text-secondary mb-1">Категория:</label>
                    <input type="text" class="form-control form-control-lg text-sm" style="font-size: 0.95rem; border-radius: 8px;" placeholder="Например: Программирование, Дизайн..." @bind="category"/>
                </div>

                <div class="col-12">
                    <label class="form-label small fw-semibold text-secondary mb-1">Сложность трека:</label>
                    <select class="form-select form-select-lg text-sm" style="font-size: 0.95rem; border-radius: 8px; height: 46px;" @bind="difficulty">
                        <option value="Beginner">Beginner (Новичок)</option>
                        <option value="Intermediate">Intermediate (Средний)</option>
                        <option value="Advanced">Advanced (Продвинутый)</option>
                    </select>
                </div>

                <div class="col-12">
                    <label class="form-label small fw-semibold text-secondary mb-1">Теги (через запятую):</label>
                    <input type="text" class="form-control form-control-lg text-sm" style="font-size: 0.95rem; border-radius: 8px;" placeholder="csharp, backend, junior" @bind="tags"/>
                </div>

                <div class="col-12 my-3">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" role="switch" id="isPublicSwitch" @bind="isPublic" style="cursor: pointer;" />
                        <label class="form-check-label small fw-medium text-dark ms-2" for="isPublicSwitch" style="cursor: pointer;">
                            📢 Сделать карту публичной (доступной в библиотеке)
                        </label>
                    </div>
                </div>

                <div class="col-12 pt-2">
                    <button type="submit" class="btn btn-primary btn-lg text-white w-100 fw-bold border-0 py-2.5 rounded-3" style="font-size: 1rem; box-shadow: 0 4px 12px rgba(37,99,235,0.15) !important;">
                        Создать и открыть холст
                    </button>
                </div>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="alert alert-danger py-2 px-3 small border-0 fw-medium mb-0 mt-3 text-start">
                ⚠️ @message
            </div>
        }
    </section>
</div>

@code {
    private string title = "";
    private string description = "";
    private string category = "General";
    private string difficulty = "Beginner";
    private string tags = "";
    private bool isPublic;
    private string message = "";

    private async Task CreateRoadmap()
    {
        if (string.IsNullOrWhiteSpace(title))
        {
            message = "Название дорожной карты обязательно для заполнения.";
            return;
        }

        message = "";
        var token = await Js.InvokeAsync<string>("jiroad.loadToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/auth/login", true);
            return;
        }

        // ИСПРАВЛЕНО: Умное переключение BaseAddress при запуске внутри Docker-контейнера
        string baseAddress = Nav.BaseUri;
        if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
        {
            baseAddress = "http://127.0.0.1:8080/";
        }

        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            
            var response = await http.PostAsJsonAsync("/api/roadmap/create", new { title, description, category, difficulty, tags, isPublic });
            if (!response.IsSuccessStatusCode)
            {
                message = "Не удалось сохранить изменения на сервере.";
                return;
            }
            
            var created = await response.Content.ReadFromJsonAsync<RoadmapDto>();
            if (created is null)
            {
                message = "Сервер вернул некорректный пустой объект.";
                return;
            }
            
            Nav.NavigateTo($"/canvas/{created.Id}", true);
        }
        catch (Exception ex)
        {
            message = $"Ошибка соединения с сервером: {ex.Message}";
        }
    }

    private async Task GoBack()
    {
        await Js.InvokeVoidAsync("history.back");
    }

    private sealed class RoadmapDto
    {
        public int Id { get; set; }
    }
}