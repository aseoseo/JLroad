@page "/roadmaps/new"
@layout WorkspaceLayout
@using System.Net.Http.Headers
@using System.Net.Http.Json
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Создание Roadmap | JIroad</PageTitle>

<button type="button" @onclick="GoBack" class="ghost" style="display: inline-flex; align-items: center; gap: 8px; border: none; padding: 5px 10px; margin-bottom: 20px; cursor: pointer; color: #64748B;">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
    </svg>
    Назад
</button>

<h1>Создание новой дорожной карты</h1>

<section class="panel">
    <form class="editor" @onsubmit="CreateRoadmap" @onsubmit:preventDefault="true">
        <div style="display: flex; flex-direction: column; gap: 1rem; max-width: 500px;">
            <div>
                <label style="font-weight: 600; font-size: 0.9rem;">Название новой карты:</label>
                <input style="width: 100%; margin-top: 0.25rem;" placeholder="Введите название..." @bind="title" required />
            </div>

            <div>
                <label style="font-weight: 600; font-size: 0.9rem;">Краткое описание:</label>
                <input style="width: 100%; margin-top: 0.25rem;" placeholder="О чем этот трек обучения?" @bind="description"/>
            </div>

            <div>
                <label style="font-weight: 600; font-size: 0.9rem;">Категория:</label>
                <input style="width: 100%; margin-top: 0.25rem;" placeholder="Например: Программирование, Дизайн..." @bind="category"/>
            </div>

            <div>
                <label style="font-weight: 600; font-size: 0.9rem;">Сложность трека:</label>
                <select style="width: 100%; margin-top: 0.25rem;" @bind="difficulty">
                    <option value="Beginner">Beginner (Новичок)</option>
                    <option value="Intermediate">Intermediate (Средний)</option>
                    <option value="Advanced">Advanced (Продвинутый)</option>
                </select>
            </div>

            <div>
                <label style="font-weight: 600; font-size: 0.9rem;">Теги (через запятую):</label>
                <input style="width: 100%; margin-top: 0.25rem;" placeholder="csharp, backend, junior" @bind="tags"/>
            </div>

            <div style="margin: 0.5rem 0;">
                <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                    <input type="checkbox" @bind="isPublic"/> 
                    <span>📢 С сделать карту публичной (доступной в библиотеке)</span>
                </label>
            </div>

            <button type="submit" class="cta" style="height: 40px; font-weight: 600;">Создать и открыть холст</button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <p class="fine" style="color: #ef4444; margin-top: 1rem; font-weight: 600;">⚠️ @message</p>
    }
</section>

@code {
    private string title = "";
    private string description = "";
    private string category = "General";
    private string difficulty = "Beginner";
    private string tags = "";
    private bool isPublic;
    private string message = "";

    private async Task CreateRoadmap()
    {
        if (string.IsNullOrWhiteSpace(title))
        {
            message = "Название дорожной карты обязательно для заполнения.";
            return;
        }

        message = "";
        var token = await Js.InvokeAsync<string>("jiroad.loadToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/auth/login", true);
            return;
        }

        // ИСПРАВЛЕНО: Умное переключение BaseAddress при запуске внутри Docker-контейнера
        string baseAddress = Nav.BaseUri;
        if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
        {
            baseAddress = "http://127.0.0.1:8080/";
        }

        try
        {
            using var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            
            var response = await http.PostAsJsonAsync("/api/roadmap/create", new { title, description, category, difficulty, tags, isPublic });
            if (!response.IsSuccessStatusCode)
            {
                message = "Не удалось сохранить изменения на сервере.";
                return;
            }
            
            var created = await response.Content.ReadFromJsonAsync<RoadmapDto>();
            if (created is null)
            {
                message = "Сервер вернул некорректный пустой объект.";
                return;
            }
            
            Nav.NavigateTo($"/canvas/{created.Id}", true);
        }
        catch (Exception ex)
        {
            message = $"Ошибка соединения с сервером: {ex.Message}";
        }
    }

    private async Task GoBack()
    {
        await Js.InvokeVoidAsync("history.back");
    }

    private sealed class RoadmapDto
    {
        public int Id { get; set; }
    }
}