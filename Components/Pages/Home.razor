@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>JIroad</PageTitle>

<section id="introSplash" class="intro-splash" aria-label="JIroad intro">
    <div class="hero-logo-wrap intro-logo" id="heroLogoWrap" aria-hidden="true">
        <svg class="hero-logo-svg" viewBox="0 0 800 800" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="800" height="800" rx="40" fill="#0A1730"/>
            <path class="anim-left" d="M250 560C290 470 330 390 390 300" stroke="#38BDF8" stroke-width="70" stroke-linecap="round" fill="none" opacity="0.95"/>
            <path class="anim-right" d="M550 560C500 470 460 390 410 300" stroke="#60A5FA" stroke-width="70" stroke-linecap="round" fill="none" opacity="0.95"/>
            <path class="anim-road" d="M400 620C400 500 410 400 400 300" stroke="#1D4ED8" stroke-width="95" stroke-linecap="round" fill="none"/>
            <path class="anim-road-dash" d="M400 590C400 500 408 410 400 330" stroke="#DBEAFE" stroke-width="10" stroke-linecap="round" stroke-dasharray="20 24" fill="none" opacity="0.9"/>
            <g class="anim-pin">
                <path d="M400 130C350 130 310 170 310 220C310 300 400 370 400 370C400 370 490 300 490 220C490 170 450 130 400 130Z" fill="#2563EB"/>
                <circle cx="400" cy="220" r="38" fill="#93C5FD"/>
            </g>
            <g class="anim-cap" transform="translate(170 390)">
                <path d="M0 30L70 0L140 30L70 60L0 30Z" fill="#334155"/>
                <path d="M40 48V90" stroke="#334155" stroke-width="8" stroke-linecap="round"/>
                <circle cx="40" cy="98" r="7" fill="#334155"/>
            </g>
            <g class="anim-flag" transform="translate(560 380)">
                <line x1="0" y1="0" x2="0" y2="110" stroke="#1E293B" stroke-width="10" stroke-linecap="round"/>
                <path d="M0 10C30 0 50 20 75 10V55C50 65 30 45 0 55V10Z" fill="#3B82F6"/>
            </g>
            <text class="anim-text" x="400" y="720" text-anchor="middle" font-family="Poppins, Arial, sans-serif" font-size="92" font-weight="700" fill="#E2E8F0">JIroad</text>
            <ellipse class="anim-shadow" cx="400" cy="740" rx="180" ry="24" fill="#2563EB" opacity="0.18"/>
        </svg>
    </div>
</section>

<main class="site site-main container-fluid p-0">
    <header class="mammut-nav page-enter bg-white border-bottom shadow-sm">
        <div class="mammut-utility d-flex flex-column flex-sm-row justify-content-between align-items-center px-3 py-1 bg-light border-bottom gap-1">
            <span class="text-secondary small fw-medium">Платформа JIroad</span>
            <div class="mammut-utility-links d-flex gap-3 small flex-wrap justify-content-center">
                <AuthorizeView>
                    <Authorized>
                        <a href="/library" class="text-decoration-none text-secondary">Публичные roadmap</a>
                        <a href="/search" class="text-decoration-none text-secondary">Поиск</a>
                        @if (context.User.IsInRole("Mentor") || context.User.IsInRole("Admin"))
                        {
                            <a href="/mentor/dashboard" class="text-decoration-none text-primary fw-semibold">Панель отслеживания</a>
                        }
                        else
                        {
                            <a href="/dashboard" class="text-decoration-none text-primary fw-semibold">Рабочая зона</a>
                        }
                    </Authorized>
                    <NotAuthorized>
                        <span class="text-muted small">🔒 Авторизуйтесь для доступа к инструментам</span>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
        
        <div class="mammut-main d-flex flex-column flex-md-row align-items-center justify-content-between p-3 gap-3">
            <a href="/" class="mammut-logo fs-4 fw-extrabold text-primary text-decoration-none style-brand" style="font-weight: 800;">JIroad</a>
            
            <nav class="mammut-links d-flex flex-wrap gap-3 justify-content-center">
                <a href="#features" class="text-decoration-none text-dark fw-medium small">Возможности</a>
                <a href="/library" class="text-decoration-none text-dark fw-medium small">Дорожные карты</a>
                <a href="/collaboration" class="text-decoration-none text-dark fw-medium small">Совместная работа</a>
                <a href="#contacts" class="text-decoration-none text-dark fw-medium small">Контакты</a>
            </nav>
            
            <div class="mammut-actions d-flex gap-2">
                <AuthorizeView>
                    <Authorized>
                        <button type="button" class="btn btn-sm btn-outline-secondary px-3" @onclick='() => Nav.NavigateTo("/profile")'>Профиль</button>
                        @if (context.User.IsInRole("Mentor") || context.User.IsInRole("Admin"))
                        {
                            <button type="button" class="btn btn-sm btn-primary text-white" @onclick='() => Nav.NavigateTo("/mentor/dashboard")'>Панель Mentora</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-sm btn-primary text-white" @onclick='() => Nav.NavigateTo("/dashboard")'>Рабочая зона</button>
                        }
                    </Authorized>
                    <NotAuthorized>
                        <button type="button" class="btn btn-sm btn-outline-primary px-3" @onclick="OpenAuthModal">Войти</button>
                        <button type="button" class="btn btn-sm btn-primary text-white px-3" @onclick="OpenAuthModal">Регистрация</button>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <section class="hero hero-centered page-enter text-center px-3 py-5 my-3 my-md-5 mx-auto" style="max-width: 800px;">
        <p class="eyebrow badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill fw-bold text-uppercase mb-3" style="font-size: 0.75rem; letter-spacing: 0.05em;">Дорожные карты обучения</p>
        <h1 class="display-5 fw-bold text-dark lh-sm mb-3">Построй свой путь обучения в одном пространстве</h1>
        <p class="lead text-secondary fs-5 mb-4 mx-auto" style="max-width: 600px;">Создавай, связывай и проходи roadmap с визуальной структурой и персональными подсказками.</p>
        <div class="hero-actions d-flex justify-content-center">
            <AuthorizeView>
                <Authorized>
                    @if (context.User.IsInRole("Mentor") || context.User.IsInRole("Admin"))
                    {
                        <button type="button" class="btn btn-primary btn-lg text-white px-4 shadow" @onclick='() => Nav.NavigateTo("/mentor/dashboard")'>Открыть треки студентов</button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary btn-lg text-white px-4 shadow" @onclick='() => Nav.NavigateTo("/dashboard")'>В рабочую зону</button>
                    }
                </Authorized>
                <NotAuthorized>
                    <button type="button" class="btn btn-primary btn-lg text-white px-5 shadow fw-bold" @onclick="OpenAuthModal">Начать работу</button>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </section>

    <section id="features" class="panel page-enter container my-5 p-4 bg-white border rounded-4 shadow-sm">
        <h2 class="h3 text-dark fw-bold mb-4 text-center text-md-start">Ключевые возможности</h2>
        <div class="row g-3 text-center">
            <div class="col-12 col-sm-6 col-md-4 col-lg-3"><article class="p-3 border rounded-3 h-100 bg-light fw-medium small">Infinite Canvas</article></div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3"><article class="p-3 border rounded-3 h-100 bg-light fw-medium small">Бесконечный холст</article></div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3"><article class="p-3 border rounded-3 h-100 bg-light fw-medium small">ИИ-генерация roadmap</article></div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3"><article class="p-3 border rounded-3 h-100 bg-light fw-medium small">Аналитика прогресса</article></div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3"><article class="p-3 border rounded-3 h-100 bg-light fw-medium small">Совместная работа</article></div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3"><article class="p-3 border rounded-3 h-100 bg-light fw-medium small">Экспорт: JSON / PNG / SVG / PDF / CSV</article></div>
            <div class="col-12 col-sm-6 col-md-4 col-lg-3"><article class="p-3 border rounded-3 h-100 bg-light fw-medium small">Гибкая настройка узлов и связей</article></div>
        </div>
    </section>

    <footer id="contacts" class="panel page-enter container my-5 p-4 bg-dark text-white border rounded-4 shadow">
        <h2 class="h4 fw-bold mb-3 text-center text-md-start">Контакты и Ресурсы</h2>
        <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-md-start pt-2">
            <a href="/dashboard" class="btn btn-sm btn-outline-light px-3">Документация</a>
            <a href="https://github.com/" target="_blank" class="btn btn-sm btn-outline-light px-3">GitHub</a>
            <a href="/403" class="btn btn-sm btn-outline-secondary px-3 text-muted">Пользовательское соглашение</a>
            <a href="/403" class="btn btn-sm btn-outline-secondary px-3 text-muted">Политика конфиденциальности</a>
        </div>
    </footer>
</main>

@if (showAuthModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;" @onclick="CloseAuthModal">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content border-0 shadow-lg p-3 rounded-4">
                <header class="modal-header border-0 pb-0 justify-content-between align-items-center">
                    <h5 class="modal-title fw-bold text-dark h4 m-0">Добро пожаловать в JIroad</h5>
                    <button type="button" class="btn-close" @onclick="CloseAuthModal"></button>
                </header>
                <main class="modal-body text-start pt-2">
                    <p class="text-secondary small">Выберите действие для продолжения работы.</p>
                    <div class="d-flex flex-column gap-2 my-3">
                        <a class="btn btn-primary text-white fw-bold py-2" href="/auth/login">Авторизация</a>
                        <a class="btn btn-light border fw-semibold py-2" href="/auth/register">Регистрация</a>
                    </div>
                </main>
                <footer class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-sm btn-outline-secondary w-100" @onclick="CloseAuthModal">Закрыть</button>
                </footer>
            </div>
        </div>
    </div>
}

@code {
    private bool showAuthModal;

    private void OpenAuthModal() => showAuthModal = true;
    private void CloseAuthModal() => showAuthModal = false;
}