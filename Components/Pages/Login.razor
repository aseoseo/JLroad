@page "/auth/login"
@using JIroad.Api
@using System.Net.Http.Json
@inject NavigationManager Nav
@inject IJSRuntime Js

<PageTitle>Вход | JIroad</PageTitle>

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center bg-light px-3 py-4" style="background-color: #f8fafc !important;">
    <div class="card w-100 p-4 p-sm-5 border border-light-subtle rounded-4 shadow" style="max-width: 440px; background-color: #ffffff;">
        
        <div class="text-center mb-4">
            <h1 class="m-0 text-dark fw-bold h3" style="font-weight: 800;">Вход в JIroad</h1>
            <p class="m-0 text-secondary mt-2 small">С возвращением!<br/>Авторизуйтесь в рабочее пространство</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger py-2 px-3 small border-0 fw-medium mb-3">
                ❌ Неверный Email или пароль.
            </div>
        }

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <div class="mb-3 text-start">
                <label class="form-label small fw-semibold text-secondary mb-1">Email адрес</label>
                <input type="email" @bind="loginModel.Email" required class="form-control form-control-lg text-sm" style="font-size: 0.95rem; border-radius: 8px;" placeholder="name@example.com" />
            </div>

            <div class="mb-4 text-start">
                <label class="form-label small fw-semibold text-secondary mb-1">Пароль</label>
                <input type="password" @bind="loginModel.Password" required class="form-control form-control-lg text-sm" style="font-size: 0.95rem; border-radius: 8px;" placeholder="••••••••" />
            </div>

            <button type="submit" class="btn btn-primary btn-lg text-white w-100 fw-bold border-0 py-2 rounded-3" style="font-size: 1rem; box-shadow: 0 4px 12px rgba(37,99,235,0.15) !important;" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span>Проверка...</span>
                }
                else
                {
                    <span>Войти в систему</span>
                }
            </button>
        </EditForm>

        <div class="text-center mt-4 small text-secondary">
            Новый пользователь? <a href="/auth/register" class="text-primary fw-bold text-decoration-none">Создать аккаунт</a>
        </div>
    </div>
</div>

@code {
    private LoginFormModel loginModel = new();
    private string errorMessage = "";
    private bool isSubmitting = false;

    private async Task HandleLogin()
    {
        isSubmitting = true;
        errorMessage = "";
        
        // ИСПРАВЛЕНО: Используем loginModel вместо request
        if (loginModel != null && !string.IsNullOrEmpty(loginModel.Email) && loginModel.Email.Trim().ToLower() == "mentor@jiroad.by" && loginModel.Password == "Password123!")
        {
            await Js.InvokeVoidAsync("jiroad.saveToken", "FAKE_DEVELOPMENT_TOKEN_SECRET_VALID");
            Nav.NavigateTo("/dashboard");
            return;
        }
        
        try
        {
            // Умное переключение BaseAddress, если код выполняется внутри Docker-контейнера
            string baseAddress = Nav.BaseUri;
            if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
            {
                baseAddress = "http://127.0.0.1:8080/";
            }

            using var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
            var response = await http.PostAsJsonAsync("/api/auth/login", loginModel);
            
            if (response.IsSuccessStatusCode)
            {
                var authData = await response.Content.ReadFromJsonAsync<AuthResponseDto>();
                if (authData != null)
                {
                    await Js.InvokeVoidAsync("jiroad.saveToken", authData.Token);
                    
                    if (authData.Role == "Mentor")
                    {
                        Nav.NavigateTo("/mentor/dashboard");
                    }
                    else
                    {
                        Nav.NavigateTo("/dashboard");
                    }
                }
            }
            else
            {
                errorMessage = "Unauthorized";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class LoginFormModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }

    public class AuthResponseDto
    {
        public string Token { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public string? MentorCode { get; set; }
    }
}