@page "/roadmap/{RoadmapId:int}/tests"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Security.Claims
@using System.IdentityModel.Tokens.Jwt
@using JIroad.Api
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Тесты и Проверка знаний | JIroad</PageTitle>

<div class="container-fluid px-2 px-md-4 my-4 text-start" style="max-width: 1200px; font-family: system-ui, -apple-system, sans-serif;">
    
    <button class="btn btn-sm btn-light border border-secondary-subtle px-3 py-2 rounded-3 mb-4" @onclick="BackToCanvas">
        ← Вернуться назад
    </button>

    <header class="p-4 mb-4 bg-white border rounded-4 shadow-sm d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h1 class="m-0 text-dark fw-bold fs-4">📝 Центр Тестирования по Roadmap #{RoadmapId}</h1>
            <p class="m-0 text-muted mt-2 small">Создавайте проверочные тесты вручную, проходите задания или используйте нейросеть для генерации среза знаний</p>
        </div>
        <div class="w-100 w-md-auto text-end">
            <button class="btn btn-primary fw-semibold px-4 py-2.5 rounded-3 text-white border-0 shadow w-100 w-sm-auto" style="background-color: #4f46e5 !important;" @onclick="GenerateTestViaAi" disabled="@isAiGenerating">
                @(isAiGenerating ? "⚡ Генерируем..." : "🤖 Сгенерировать через ИИ")
            </button>
        </div>
    </header>

    @if (activeTest != null)
    {
        <div class="card p-4 p-sm-5 bg-white border border-light-subtle rounded-4 shadow-sm">
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center border-bottom pb-3 mb-4 gap-2">
                <h2 class="h4 m-0 text-dark fw-bold">🎯 Прохождение: @activeTest.Title</h2>
                <button class="btn btn-sm btn-outline-danger px-3 py-2 rounded-3" style="background-color: #fee2e2 !important; color: #b91c1c !important; border: none;" @onclick="CancelTesting">Прервать тест</button>
            </div>

            @if (!testFinished)
            {
                @foreach (var q in activeTest.Questions)
                {
                    <div class="p-4 bg-light border border-light-subtle rounded-3 mb-4">
                        <p class="fw-bold text-dark mb-3 fs-6">❓ @q.QuestionText</p>
                        <div class="d-flex flex-column gap-2">
                            @foreach (var opt in q.Options)
                            {
                                <label class="form-check-label border border-secondary-subtle rounded-3 p-3 bg-white d-flex align-items-center gap-3 w-100" style="cursor: pointer;">
                                    <input type="radio" class="form-check-input m-0 flex-shrink-0" style="width: 1.15rem; height: 1.15rem;" name="question-@q.Id" @onclick="() => SelectAnswer(q.Id, opt.Id)" />
                                    <span class="text-secondary small fw-medium">@opt.OptionText</span>
                                </label>
                            }
                        </div>
                    </div>
                }

                <button class="btn btn-success btn-lg text-white w-100 fw-bold py-3 rounded-3 border-0 mt-3" @onclick="SubmitAnswers">
                    🏁 Завершить тест и проверить результаты
                </button>
            }
            else
            {
                <div class="text-center py-4">
                    <span class="display-1 d-block mb-2">🏆</span>
                    <h2 class="h3 text-dark fw-bold mt-2">Тест успешно завершен!</h2>
                    <p class="display-6 fw-extrabold text-primary my-3" style="font-weight: 800;">Ваш результат: @userScore из @totalQuestions</p>
                    <p class="text-muted small mb-4">Попытка зафиксирована в общей аналитике профиля.</p>
                    <button class="btn btn-primary fw-semibold px-4 py-2 rounded-3 text-white border-0 shadow" style="background-color: #4f46e5 !important;" @onclick="CancelTesting">Вернуться к списку тестов</button>
                </div>
            }
        </div>
    }
    else
    {
        <div class="row g-4">
            
            <section class="col-12 col-lg-6">
                <div class="card p-4 bg-white border border-light-subtle rounded-4 shadow-sm h-100">
                    <h3 class="h5 text-dark fw-bold border-bottom pb-2 mb-3">📋 Доступные проверочные тесты</h3>
                    
                    @if (testList == null || testList.Count == 0)
                    {
                        <p class="text-muted fst-italic text-center py-5 my-auto small">Для этой карты пока не создано ни одного теста.</p>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-2 overflow-y-auto pe-1" style="max-height: 600px;">
                            @foreach (var t in testList)
                            {
                                <div class="p-3 border border-light-subtle rounded-3 bg-light d-flex justify-content-between align-items-center gap-3 shadow-sm">
                                    <div class="text-truncate" style="flex: 1;">
                                        <h4 class="h6 m-0 text-dark fw-bold text-truncate">
                                            @t.Title 
                                            @if (t.IsAiGenerated) { <span class="badge bg-purple-subtle text-purple px-2 py-1 small rounded ms-1" style="background-color: #f3e8ff; color: #7c3aed; font-size: 0.7rem;">🤖 ИИ</span> }
                                        </h4>
                                        <p class="text-muted small m-0 mt-1 text-truncate">@t.Description</p>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-primary text-white fw-bold px-3 py-2 rounded-3 border-0 flex-shrink-0" @onclick="() => StartTest(t.Id)">Пройти</button>
                                </div>
                            }
                        </div>
                    }
                </div>
            </section>

            <section class="col-12 col-lg-6">
                <div class="card p-4 bg-white border border-light-subtle rounded-4 shadow-sm h-100">
                    <h3 class="h5 text-dark fw-bold border-bottom pb-2 mb-3">🛠️ Конструктор нового теста</h3>
                    
                    <div class="d-flex flex-column gap-3">
                        <div>
                            <label class="form-label small fw-semibold text-secondary mb-1">Название теста:</label>
                            <input type="text" @bind="newTestTitle" class="form-control form-control-sm text-sm" style="font-size: 0.95rem; border-radius: 6px;" placeholder="Например: Итоговый контроль по С#" />
                        </div>
                        <div>
                            <label class="form-label small fw-semibold text-secondary mb-1">Краткое описание / Инструкция:</label>
                            <textarea @bind="newTestDesc" class="form-control form-control-sm text-sm" style="font-size: 0.95rem; border-radius: 6px; height: 60px;" placeholder="Введите основные правила сдачи теста..."></textarea>
                        </div>

                        <div class="border-top border-secondary-subtle border-dashed pt-3 mt-2">
                            <h4 class="h6 text-dark fw-bold mb-3">Вопросы квиза (@newQuestions.Count)</h4>
                            
                            <div class="p-3 border border-light-subtle rounded-3 mb-3 bg-light">
                                <input type="text" @bind="currentQuestionText" class="form-control form-control-sm mb-3 text-sm" placeholder="Текст вопроса..." />
                                
                                <div class="d-flex flex-column gap-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="radio" class="form-check-input m-0 flex-shrink-0" name="correct-opt" checked="@(correctOptIndex == 0)" @onclick="() => correctOptIndex = 0" style="width: 1.1rem; height: 1.1rem;" />
                                        <input type="text" @bind="opt1" class="form-control form-control-sm text-xs" style="font-size: 0.85rem;" placeholder="Вариант 1 (Отметьте точку, если правильный)" />
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="radio" class="form-check-input m-0 flex-shrink-0" name="correct-opt" checked="@(correctOptIndex == 1)" @onclick="() => correctOptIndex = 1" style="width: 1.1rem; height: 1.1rem;" />
                                        <input type="text" @bind="opt2" class="form-control form-control-sm text-xs" style="font-size: 0.85rem;" placeholder="Вариант 2" />
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="radio" class="form-check-input m-0 flex-shrink-0" name="correct-opt" checked="@(correctOptIndex == 2)" @onclick="() => correctOptIndex = 2" style="width: 1.1rem; height: 1.1rem;" />
                                        <input type="text" @bind="opt3" class="form-control form-control-sm text-xs" style="font-size: 0.85rem;" placeholder="Вариант 3 (Необязательно)" />
                                    </div>
                                </div>
                                <button type="button" class="btn btn-sm btn-light border w-100 fw-bold py-2 mt-3 rounded-3" @onclick="AddQuestionToStack">
                                    ➕ Добавить вопрос в структуру
                                </button>
                            </div>
                        </div>

                        <button type="button" class="btn btn-success fw-bold py-2.5 rounded-3 border-0 text-white shadow-sm w-100 mt-2" @onclick="SaveManualTest">
                            💾 Опубликовать и сохранить тест
                        </button>
                    </div>
                </div>
            </section>
        </div>
    }
</div>

@code {
    [Parameter] public int RoadmapId { get; set; }

    private string token = "";
    private string userRole = "Student"; 
    private bool isAiGenerating = false;

    private List<TestListDto> testList = [];
    private TestResponse? activeTest = null;
    private Dictionary<int, int> userAnswers = [];

    private bool testFinished = false;
    private int userScore = 0;
    private int totalQuestions = 0;

    private string newTestTitle = "";
    private string newTestDesc = "";
    private List<CreateQuestionRequest> newQuestions = [];
    private string currentQuestionText = "";
    private string opt1 = "";
    private string opt2 = "";
    private string opt3 = "";
    private int correctOptIndex = 0;

    public class TestListDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public bool IsAiGenerated { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        token = await Js.InvokeAsync<string>("jiroad.loadToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/auth/login", true);
            return;
        }

        try
        {
            var handler = new JwtSecurityTokenHandler();
            var jwtToken = handler.ReadJwtToken(token);
            userRole = jwtToken.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role || c.Type == "role")?.Value ?? "Student";
        }
        catch
        {
            userRole = "Student";
        }

        await LoadTests();
    }

    private HttpClient Client()
    {
        // ИСПРАВЛЕНО: Умное переключение BaseAddress при выполнении кода внутри Docker-контейнера
        string baseAddress = Nav.BaseUri;
        if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
        {
            baseAddress = "http://127.0.0.1:8080/";
        }

        var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
        http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return http;
    }

    private async Task LoadTests()
    {
        try
        {
            using var http = Client();
            testList = await http.GetFromJsonAsync<List<TestListDto>>($"/api/roadmap/{RoadmapId}/tests") ?? [];
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ОШИБКА ЗАГРУЗКИ ТЕСТОВ]: {ex.Message}");
        }
    }

    private async Task StartTest(int testId)
    {
        try
        {
            using var http = Client();
            activeTest = await http.GetFromJsonAsync<TestResponse>($"/api/roadmap/tests/{testId}");
            userAnswers.Clear();
            testFinished = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ОШИБКА ЗАПУСКА ТЕСТА]: {ex.Message}");
        }
    }

    private void SelectAnswer(int questionId, int optionId)
    {
        userAnswers[questionId] = optionId;
    }

    private async Task SubmitAnswers()
    {
        if (activeTest == null) return;

        try
        {
            using var http = Client();
            var submissions = userAnswers.Select(x => new AnswerSubmissionDto(x.Key, x.Value)).ToList();
            var payload = new SubmitTestRequest(submissions);

            var response = await http.PostAsJsonAsync($"/api/roadmap/tests/{activeTest.Id}/submit", payload);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<SubmitResultDto>();
                if (result != null)
                {
                    userScore = result.Score;
                    totalQuestions = result.TotalQuestions;
                    testFinished = true;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ОШИБКА ОТПРАВКИ ТЕСТА]: {ex.Message}");
        }
    }

    private void AddQuestionToStack()
    {
        if (string.IsNullOrWhiteSpace(currentQuestionText) || string.IsNullOrWhiteSpace(opt1) || string.IsNullOrWhiteSpace(opt2))
        {
            return;
        }

        var options = new List<CreateOptionRequest>
        {
            new CreateOptionRequest(opt1, correctOptIndex == 0),
            new CreateOptionRequest(opt2, correctOptIndex == 1)
        };

        if (!string.IsNullOrWhiteSpace(opt3))
        {
            options.Add(new CreateOptionRequest(opt3, correctOptIndex == 2));
        }

        newQuestions.Add(new CreateQuestionRequest(currentQuestionText, options));

        currentQuestionText = "";
        opt1 = "";
        opt2 = "";
        opt3 = "";
        correctOptIndex = 0;
    }

    private async Task SaveManualTest()
    {
        if (string.IsNullOrWhiteSpace(newTestTitle) || !newQuestions.Any())
        {
            await Js.InvokeVoidAsync("alert", "Введите название теста и добавьте хотя бы один вопрос!");
            return;
        }

        try
        {
            using var http = Client();
            var payload = new CreateTestRequest(newTestTitle, newTestDesc, newQuestions);
            var response = await http.PostAsJsonAsync($"/api/roadmap/{RoadmapId}/tests", payload);

            if (response.IsSuccessStatusCode)
            {
                newTestTitle = "";
                newTestDesc = "";
                newQuestions.Clear();
                await LoadTests();
                await Js.InvokeVoidAsync("alert", "🚀 Тест успешно опубликован!");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ОШИБКА СОХРАНЕНИЯ ТЕСТА]: {ex.Message}");
        }
    }

    private async Task GenerateTestViaAi()
    {
        isAiGenerating = true;
        StateHasChanged();

        try
        {
            using var http = Client();
            var response = await http.PostAsync($"/api/roadmap/{RoadmapId}/tests/ai-generate", null);
            if (response.IsSuccessStatusCode)
            {
                await LoadTests();
                await Js.InvokeVoidAsync("alert", "🤖 ИИ успешно проанализировал вашу карту и сгенерировал новый тест!");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ОШИБКА ИИ ГЕНЕРАЦИИ]: {ex.Message}");
        }
        finally
        {
            isAiGenerating = false;
            StateHasChanged();
        }
    }

    private void CancelTesting() => activeTest = null;

    private void BackToCanvas()
    {
        if (userRole == "Mentor" || userRole == "Admin")
        {
            Nav.NavigateTo("/mentor/dashboard");
        }
        else
        {
            Nav.NavigateTo($"/canvas/{RoadmapId}");
        }
    }

    public class SubmitResultDto
    {
        public int Score { get; set; }
        public int TotalQuestions { get; set; }
    }
}