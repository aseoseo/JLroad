@page "/search"
@layout WorkspaceLayout
@using System.Net.Http.Headers
@using System.Net.Http.Json
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Поиск | JIroad</PageTitle>

<div class="container-fluid px-2 px-md-4 my-4 text-start" style="max-width: 1200px; font-family: system-ui, sans-serif;">
    
    <h1 class="h3 text-dark fw-bold mb-4">Поиск</h1>
    
    <section class="card p-4 border border-light-subtle rounded-4 shadow-sm bg-white mb-4">
        <form @onsubmit="RunSearch" @onsubmit:preventDefault="true">
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <input type="text" class="form-control text-sm" style="font-size: 0.95rem; height: 42px; border-radius: 8px;" placeholder="Поиск roadmap, узлов, пользователей..." @bind="q" />
                </div>
                
                <div class="col-12 col-sm-6 col-md-2">
                    <select class="form-select text-sm" style="font-size: 0.95rem; height: 42px; border-radius: 8px;" @bind="difficulty">
                        <option value="">Сложность: любая</option>
                        <option>Beginner</option>
                        <option>Intermediate</option>
                        <option>Advanced</option>
                    </select>
                </div>
                
                <div class="col-12 col-sm-6 col-md-2">
                    <input type="text" class="form-control text-sm" style="font-size: 0.95rem; height: 42px; border-radius: 8px;" placeholder="Категория" @bind="category" />
                </div>
                
                <div class="col-12 col-sm-6 col-md-2">
                    <select class="form-select text-sm" style="font-size: 0.95rem; height: 42px; border-radius: 8px;" @bind="searchScope">
                        <option value="all">Искать везде</option>
                        <option value="my">Мои дорожные карты</option>
                        <option value="public">Общая библиотека</option>
                    </select>
                </div>
                
                <div class="col-12 col-sm-6 col-md-2">
                    <button type="submit" class="btn btn-primary fw-bold text-white w-100 rounded-3" style="height: 42px;">Найти</button>
                </div>
            </div>
        </form>
    </section>

    <section class="w-100">
        @if (isSearched && !items.Any())
        {
            <div class="p-4 bg-white border rounded-3 text-center text-muted shadow-sm">
                Ничего не найдено по вашему запросу.
            </div>
        }
        
        <div class="row g-3">
            @foreach (var roadmap in items)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 bg-white border border-light-subtle rounded-3 p-4 d-flex flex-column justify-content-between shadow-sm">
                        <div>
                            <div class="mb-2">
                                @if (roadmap.IsPublic)
                                {
                                    <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle py-1 px-2 rounded small fw-bold" style="font-size: 0.75rem;">Общая библиотека</span>
                                }
                                else
                                {
                                    <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle py-1 px-2 rounded small fw-bold" style="font-size: 0.75rem;">Личная</span>
                                }
                            </div>
                            <h3 class="h6 text-dark fw-bold text-truncate mb-2" title="@roadmap.Title">@roadmap.Title</h3>
                            <p class="text-secondary small mb-4">@roadmap.Category · @roadmap.Difficulty · @roadmap.Progress%</p>
                        </div>
                        <div class="pt-2 border-top border-light-subtle text-end">
                            <a href="/canvas/@roadmap.Id" class="btn btn-sm btn-outline-primary px-3 rounded-3 fw-semibold">Открыть</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
</div>

@code {
    private string q = "";
    private string difficulty = "";
    private string category = "";
    
    // ДОБАВЛЕНО: Переменные для управления областью поиска
    private string searchScope = "all"; 
    private bool isSearched = false;
    
    private List<RoadmapDto> items = [];

    private async Task RunSearch()
    {
        var token = await Js.InvokeAsync<string>("jiroad.loadToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/auth/login", true);
            return;
        }

        // ИСПРАВЛЕНО ДЛЯ DOCKER: Умное переключение BaseAddress, если код выполняется внутри контейнера
        string baseAddress = Nav.BaseUri;
        if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
        {
            baseAddress = "http://127.0.0.1:8080/";
        }

        using var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
        http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        
        // ОБНОВЛЕНО: Добавлен параметр scope в URL запроса к твоему API
        var url = $"/api/roadmap/search?q={Uri.EscapeDataString(q)}&difficulty={Uri.EscapeDataString(difficulty)}&category={Uri.EscapeDataString(category)}&scope={Uri.EscapeDataString(searchScope)}";
        
        items = await http.GetFromJsonAsync<List<RoadmapDto>>(url) ?? [];
        isSearched = true;
    }

    private sealed class RoadmapDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Category { get; set; } = "";
        public string Difficulty { get; set; } = "";
        public int Progress { get; set; }
        
        // ДОБАВЛЕНО: Свойство для понимания, является ли карта публичным шаблоном
        public bool IsPublic { get; set; }
    }
}