@page "/profile"
@layout WorkspaceLayout
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using JIroad.Api
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Мой Профиль | JIroad</PageTitle>

<main class="site">
    <section class="panel profile-page" style="max-width: 600px; margin: 40px auto; padding: 30px;">
        <h1>Личный кабинет</h1>
        <p class="fine">Управление вашим аккаунтом и просмотр информации.</p>

        @if (isLoading)
        {
            <div class="text-center p-4">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="fine mt-2">Загрузка данных профиля...</p>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(error) && profile == null)
        {
            <p class="fine" style="color:#b42318;">@error</p>
            <button type="button" class="cta" @onclick='() => Nav.NavigateTo("/auth/login")'>Войти в аккаунт</button>
        }
        else if (profile != null)
        {
            <div class="profile-info mt-4" style="display: flex; flex-direction: column; gap: 15px;">
                <div style="display: flex; align-items: center; gap: 15px; border-bottom: 1px solid #eee; padding-bottom: 15px;">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold" 
                         style="width: 64px; height: 64px; font-size: 24px;">
                        @(string.IsNullOrWhiteSpace(profile.UserName) ? "U" : profile.UserName.Substring(0, 1).ToUpper())
                    </div>
                    <div>
                        <h3 style="margin: 0;">@profile.UserName</h3>
                        <span class="badge @(profile.Role == "Mentor" ? "bg-warning text-dark" : "bg-info text-white")">
                            @(profile.Role == "Mentor" ? "Преподаватель / Ментор" : "Обучающийся / Студент")
                        </span>
                    </div>
                </div>

                <form @onsubmit="UpdateProfile" @onsubmit:preventDefault="true" style="display: flex; flex-direction: column; gap: 12px;">
                    <label class="fine">Email (не подлежит изменению)</label>
                    <input type="email" value="@profile.Email" disabled style="background: #f5f5f5; cursor: not-allowed;" />

                    @if (profile.Role == "Mentor")
                    {
                        <label class="fine" style="color: #b7791f; font-weight: 600;">🔑 Ваш инвайт-код ментора (для регистрации студентов)</label>
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <input type="text" value="@profile.MentorCode" disabled style="background: #fff8e6; font-weight: bold; color: #b7791f; border: 1px solid #fbd38d; flex: 1; padding: 10px; border-radius: 4px; text-align: center; font-size: 1.1rem; letter-spacing: 1px;" />
                            <button type="button" class="cta" @onclick="CopyMentorCode" style="padding: 0 15px; height: 42px; background: #b7791f; border-color: #b7791f; margin: 0; display: inline-flex; align-items: center; gap: 5px;">
                                📋 Копировать
                            </button>
                        </div>
                    }

                    <label class="fine">Имя пользователя</label>
                    <input type="text" @bind="username" placeholder="Ваше имя" required />

                    <label class="fine">О себе (Bio)</label>
                    <textarea @bind="bio" placeholder="Расскажите о себе или ваших целях обучения" rows="3" style="width:100%; padding: 10px; border-radius: 4px; border: 1px solid #ccc; font-family: inherit;"></textarea>

                    @if (!string.IsNullOrWhiteSpace(successMessage))
                    {
                        <p class="fine" style="color: #027a48;">@successMessage</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(error))
                    {
                        <p class="fine" style="color: #b42318;">@error</p>
                    }

                    <button type="submit" class="cta" style="margin-top: 10px;">Сохранить изменения</button>
                </form>

                <div class="border-top mt-4 pt-3">
                    <button type="button" class="ghost text-danger" @onclick="Logout" style="width: 100%;">Выйти из аккаунта</button>
                </div>
            </div>
        }
    </section>
</main>

@code {
    private bool isLoading = true;
    private string error = "";
    private string successMessage = "";
    
    private UserProfileResponse? profile;
    private string username = "";
    private string bio = "";
    private string token = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await LoadProfile();
    }

    private string GetBaseAddress()
    {
        // ИСПРАВЛЕНО ДЛЯ DOCKER: Умное переключение BaseAddress, если код выполняется внутри контейнера
        string baseAddress = Nav.BaseUri;
        if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
        {
            baseAddress = "http://127.0.0.1:8080/";
        }
        return baseAddress;
    }

    private async Task LoadProfile()
    {
        try
        {
            isLoading = true;
            error = "";
            StateHasChanged();

            token = await Js.InvokeAsync<string>("eval", @"
                (() => {
                    for (let i = 0; i < localStorage.length; i++) {
                        let k = localStorage.key(i);
                        let v = localStorage.getItem(k);
                        if (v && v.startsWith('eyJ')) return v;
                    }
                    return '';
                })()
            ");

            if (string.IsNullOrWhiteSpace(token))
            {
                error = "Вы не авторизованы. Пожалуйста, войдите в систему.";
                isLoading = false;
                StateHasChanged();
                return;
            }

            using var http = new HttpClient { BaseAddress = new Uri(GetBaseAddress()) };
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var response = await http.GetAsync("/api/roadmap/profile");
            if (response.IsSuccessStatusCode)
            {
                profile = await response.Content.ReadFromJsonAsync<UserProfileResponse>();
                if (profile != null)
                {
                    username = profile.UserName;
                    bio = profile.Bio;
                }
            }
            else
            {
                error = "Не удалось загрузить профиль. Сессия устарела.";
            }
        }
        catch
        {
            error = "Ошибка подключения к серверу.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task UpdateProfile()
    {
        try
        {
            successMessage = "";
            error = "";

            using var http = new HttpClient { BaseAddress = new Uri(GetBaseAddress()) };
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var requestPayload = new { 
                userName = username, 
                avatarUrl = profile?.AvatarUrl ?? "", 
                bio = bio,
                language = "ru",
                theme = "dark"
            };

            var response = await http.PutAsJsonAsync("/api/roadmap/profile", requestPayload);
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Изменения успешно сохранены!";
            }
            else
            {
                error = "Не удалось обновить профиль.";
            }
        }
        catch
        {
            error = "Ошибка отправки данных.";
        }
    }

    private async Task CopyMentorCode()
    {
        if (profile != null && !string.IsNullOrEmpty(profile.MentorCode))
        {
            await Js.InvokeVoidAsync("navigator.clipboard.writeText", profile.MentorCode);
            successMessage = "Инвайт-код ментора успешно скопирован в буфер обмена!";
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await Js.InvokeVoidAsync("eval", @"
            localStorage.clear();
            sessionStorage.clear();
        ");
        Nav.NavigateTo("/", forceLoad: true);
    }
}