@page "/analytics/{RoadmapId:int}"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Globalization
@using JIroad.Api
@inject IJSRuntime Js
@inject NavigationManager Nav

<PageTitle>Аналитика прогресса | JIroad</PageTitle>

<div class="container-fluid px-2 px-md-4 my-4" style="max-width: 1100px; font-family: system-ui, sans-serif;">
    
    <header class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center pb-3 mb-4 border-bottom gap-2">
        <div>
            <button class="btn btn-sm btn-outline-secondary mb-2" @onclick="BackToCanvas">← Вернуться к карте</button>
            <h1 class="m-0 text-dark" style="font-size: 1.75rem; font-weight: 700;">📊 Аналитика и метрики прогресса</h1>
            <p class="m-0 text-muted small" style="margin-top: 0.25rem !important;">Детальный отчет по дорожной карте #@RoadmapId</p>
        </div>
        <div>
            <button class="btn btn-primary w-100" @onclick="RefreshData">🔄 Обновить данные</button>
        </div>
    </header>

    @if (_isLoading)
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 200px;">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (_data is null || _data.TotalNodes == 0)
    {
        <div class="alert alert-info text-center p-5 shadow-sm rounded-3">
            <h3>Сбор метрик невозможен</h3>
            <p class="m-0">Добавьте хотя бы один обучающий узел (этап) на холст карты, чтобы система рассчитала аналитику.</p>
        </div>
    }
    else
    {
        <section class="row g-3 mb-4">
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 text-center p-3 border border-light-subtle shadow-sm rounded-3">
                    <div class="text-uppercase small fw-bold text-muted">Всего этапов</div>
                    <div class="display-6 fw-bold text-dark mt-1">@_data.TotalNodes</div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 text-center p-3 border border-light-subtle shadow-sm rounded-3 style-completed-border" style="border-left: 4px solid #22c55e !important;">
                    <div class="text-uppercase small fw-bold text-muted">Пройдено</div>
                    <div class="display-6 fw-bold text-success mt-1">@_data.CompletedNodes</div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 text-center p-3 border border-light-subtle shadow-sm rounded-3 style-progress-border" style="border-left: 4px solid #3b82f6 !important;">
                    <div class="text-uppercase small fw-bold text-muted">В процессе</div>
                    <div class="display-6 fw-bold text-primary mt-1">@_data.InProgressNodes</div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 text-center p-3 border border-light-subtle shadow-sm rounded-3">
                    <div class="text-uppercase small fw-bold text-muted">Общий прогресс</div>
                    <div class="display-6 fw-bold text-dark mt-1">@_data.OverallProgress%</div>
                </div>
            </div>
        </section>

        <section class="row g-4 mb-4">
            
            <div class="col-12 col-lg-6">
                <div class="card h-100 p-4 border border-light-subtle shadow-sm rounded-3 d-flex flex-column align-items-center">
                    <h3 class="w-100 text-start text-dark mb-4" style="font-size: 1.1rem; font-weight: 600;">🍩 Распределение задач по статусам</h3>
                    
                    @{
                        double total = _data.TotalNodes;
                        double complDeg = (_data.CompletedNodes / total) * 360;
                        double progDeg = (_data.InProgressNodes / total) * 360;
                        double planDeg = (_data.PlannedNodes / total) * 360;
                    }
                    
                    <div class="d-flex flex-column flex-sm-row align-items-center justify-content-center gap-4 w-100 my-auto">
                        <div class="donut-chart-wrapper">
                            <svg width="160" height="160" viewBox="0 0 42 42" class="donut-chart-svg">
                                <circle cx="21" cy="21" r="15.915" fill="transparent" stroke="#e2e8f0" stroke-width="4.5"></circle>
                                
                                <circle cx="21" cy="21" r="15.915" fill="transparent" stroke="#22c55e" stroke-width="4.5" 
                                        stroke-dasharray="@($"{((_data.CompletedNodes/total)*100).ToString(CultureInfo.InvariantCulture)} {((1 - _data.CompletedNodes/total)*100).ToString(CultureInfo.InvariantCulture)}")" stroke-dashoffset="25"></circle>
                                
                                <circle cx="21" cy="21" r="15.915" fill="transparent" stroke="#3b82f6" stroke-width="4.5" 
                                        stroke-dasharray="@($"{((_data.InProgressNodes/total)*100).ToString(CultureInfo.InvariantCulture)} {((1 - _data.InProgressNodes/total)*100).ToString(CultureInfo.InvariantCulture)}")" 
                                        stroke-dashoffset="@((25 - (_data.CompletedNodes/total)*100).ToString(CultureInfo.InvariantCulture))"></circle>
                            </svg>
                        </div>

                        <div class="d-flex flex-column gap-2 text-start">
                            <div class="d-flex align-items-center gap-2 small">
                                <span style="width: 12px; height: 12px; background: #22c55e; border-radius: 3px; display: inline-block;"></span>
                                <span>Завершено: <b>@_data.CompletedNodes</b></span>
                            </div>
                            <div class="d-flex align-items-center gap-2 small">
                                <span style="width: 12px; height: 12px; background: #3b82f6; border-radius: 3px; display: inline-block;"></span>
                                <span>В изучении: <b>@_data.InProgressNodes</b></span>
                            </div>
                            <div class="d-flex align-items-center gap-2 small">
                                <span style="width: 12px; height: 12px; background: #64748b; border-radius: 3px; display: inline-block;"></span>
                                <span>Запланировано: <b>@_data.PlannedNodes</b></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="card h-100 p-4 border border-light-subtle shadow-sm rounded-3">
                    <h3 class="text-dark mb-4" style="font-size: 1.1rem; font-weight: 600;">📊 Направленность обучения (по типам контента)</h3>
                    
                    <div class="d-flex flex-column gap-3">
                        @foreach (var typeBucket in _data.NodesByType)
                        {
                            int maxCount = _data.NodesByType.Max(x => x.Count);
                            double barWidthPercent = maxCount > 0 ? ((double)typeBucket.Count / maxCount) * 100 : 0;
                            
                            <div>
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-secondary fw-medium">@typeBucket.Type</span>
                                    <span class="text-dark fw-bold">@typeBucket.Count</span>
                                </div>
                                <div class="w-100 bg-light-subtle" style="height: 12px; border-radius: 6px; overflow: hidden; background-color: #f1f5f9;">
                                    <div style="width: @barWidthPercent.ToString(CultureInfo.InvariantCulture)%; background: #6366f1; height: 100%; border-radius: 6px;"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </section>

        <section class="row g-4">
            
            <div class="col-12 col-md-5 col-lg-4">
                <div class="card h-100 p-4 border border-light-subtle shadow-sm rounded-3">
                    <h3 class="text-dark mb-3" style="font-size: 1.1rem; font-weight: 600;">⚡ Сложность</h3>
                    <div class="table-responsive">
                        <table class="table table-sm table-borderless m-0 align-middle small">
                            <thead>
                                <tr class="border-bottom">
                                    <th class="pb-2">Уровень</th>
                                    <th class="text-end pb-2">Кол-во</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var diff in _data.NodesByDifficulty)
                                {
                                    <tr>
                                        <td class="py-2 text-secondary">@diff.Difficulty</td>
                                        <td class="text-end py-2 fw-bold text-dark">@diff.Count</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-7 col-lg-8">
                <div class="card h-100 p-4 border border-light-subtle shadow-sm rounded-3">
                    <h3 class="text-dark mb-3" style="font-size: 1.1rem; font-weight: 600;">📝 Сводный текстовый отчет по карте</h3>
                    
                    <div class="p-3 border-0 rounded-3 text-secondary lh-lg" style="background-color: #f8fafc; font-size: 0.95rem;">
                        <p class="mt-0 mb-2">
                            Текущий уровень готовности дорожной карты составляет <b>@_data.OverallProgress%</b>. 
                            Архитектура содержит в себе <b>@_data.TotalNodes</b> основных этапов обучения, соединенных <b>@_data.TotalEdges</b> связями зависимостей.
                        </p>
                        
                        @if (_data.OverallProgress >= 80)
                        {
                            <p class="text-success fw-medium m-0">🏆 Отличный результат! Специализация практически полностью освоена и закреплена на холсте.</p>
                        }
                        else if (_data.OverallProgress > 30)
                        {
                            <p class="text-primary fw-medium m-0">🚀 Хороший темп. Рекомендуется уделить внимание связям типа «Альтернативный путь» для расширения квалификации.</p>
                        }
                        else
                        {
                            <p class="text-warning fw-medium m-0" style="color: #9a3412 !important;">⏳ Обучение находится на начальной стадии. Начните планомерно проходить «Planned» этапы.</p>
                        }
                    </div>
                </div>
            </div>
        </section>
    }
</div>

@code {
    [Parameter] public int RoadmapId { get; set; }

    private string token = "";
    private bool _isLoading = true;
    private RoadmapAnalyticsResponse? _data = null;

    protected override async Task OnInitializedAsync()
    {
        token = await Js.InvokeAsync<string>("jiroad.loadToken");
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/auth/login", true);
            return;
        }
        await LoadAnalytics();
    }

    private HttpClient Client()
    {
        // ИСПРАВЛЕНО ДЛЯ DOCKER: Динамическое переключение BaseAddress внутри Docker-сети
        string baseAddress = Nav.BaseUri;
        if (Environment.GetEnvironmentVariable("DOTNET_RUNNING_IN_CONTAINER") == "true")
        {
            baseAddress = "http://127.0.0.1:8080/";
        }

        var http = new HttpClient { BaseAddress = new Uri(baseAddress) };
        http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        return http;
    }

    private async Task LoadAnalytics()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            using var http = Client();
            _data = await http.GetFromJsonAsync<RoadmapAnalyticsResponse>($"/api/roadmap/{RoadmapId}/analytics");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ОШИБКА АНАЛИТИКИ] Не удалось загрузить метрики: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private Task RefreshData() => LoadAnalytics();

    private void BackToCanvas() => Nav.NavigateTo($"/canvas/{RoadmapId}");

    private string GetStatusText(string status) => status switch
    {
        "Planned" => "Не начато",
        "In Progress" => "В процессе",
        "Completed" => "Завершено",
        _ => status
    };
}