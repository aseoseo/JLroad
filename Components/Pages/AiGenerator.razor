@page "/ai-generator"
@layout WorkspaceLayout
@using System.Security.Claims
@using JIroad.Data
@using JIroad.Data.Entities
@using JIroad.Services
@using Microsoft.EntityFrameworkCore
@inject IJSRuntime Js
@inject NavigationManager Nav
@inject AppDbContext Db
@inject AiService Ai

<PageTitle>ИИ Генератор треков | JIroad</PageTitle>

<section class="panel page-enter px-2 px-md-3">
    <div style="margin-bottom: 1.5rem;">
        <h2 style="display: flex; align-items: center; gap: 0.5rem; margin: 0; flex-wrap: wrap;">🤖 Генерация дорожной карты через ИИ</h2>
        <p class="fine" style="margin-top: 0.35rem;">Укажите желаемую цель, и нейросеть автоматически спроектирует оптимальные этапы обучения, связи между ними и подберет полезные материалы.</p>
    </div>

    <form @onsubmit="HandleGenerateSubmit" @onsubmit:preventDefault="true">
        <div class="editor container-fluid m-0" style="max-width: 650px; background: #ffffff; padding: 1.5rem; border: 1px solid #e2e8f0; border-radius: 12px;">
            <div class="row g-3">
                
                <div class="col-12">
                    <label style="font-weight: 700; font-size: 0.9rem; color: #1e293b;">🎯 Какую технологию или профессию хотите освоить?</label>
                    <input type="text" class="form-control" style="width: 100%; margin-top: 0.4rem; box-sizing: border-box;" 
                           @bind="goal" 
                           placeholder="Например: Изучить C# и ASP.NET Core до уровня Junior" 
                           disabled="@isGenerating" required />
                </div>

                <div class="col-12">
                    <label style="font-weight: 700; font-size: 0.9rem; color: #1e293b;">⏱️ Сколько времени вы готовы выделить (Таймлайн)?</label>
                    <input type="text" class="form-control" style="width: 100%; margin-top: 0.4rem; box-sizing: border-box;" 
                           @bind="timeline" 
                           placeholder="Например: 2 месяца, по 15 часов в неделю" 
                           disabled="@isGenerating" required />
                </div>

                <div class="col-12 col-md-6">
                    <label style="font-weight: 700; font-size: 0.9rem; color: #1e293b;">📊 Текущий уровень:</label>
                    <select class="form-select" style="width: 100%; margin-top: 0.4rem; box-sizing: border-box; height: 38px;" @bind="currentLevel" disabled="@isGenerating">
                        <option value="Beginner">Новичок (Beginner)</option>
                        <option value="Intermediate">Средний (Intermediate)</option>
                        <option value="Advanced">Продвинутый (Advanced)</option>
                    </select>
                </div>

                <div class="col-12 col-md-6">
                    <label style="font-weight: 700; font-size: 0.9rem; color: #1e293b;">📂 Общая категория:</label>
                    <input type="text" class="form-control" style="width: 100%; margin-top: 0.4rem; box-sizing: border-box;" 
                           @bind="category" 
                           placeholder="Например: Программирование" 
                           disabled="@isGenerating" required />
                </div>

                <div class="col-12 pt-2">
                    <button type="submit" class="cta start-btn" style="width: 100%; justify-content: center; height: 46px; font-weight: 700;" disabled="@isGenerating">
                        @if (isGenerating)
                        {
                            <span class="save-spinner" style="margin-right: 8px;"></span>
                            <span>🧠 ИИ строит граф связей... Подождите</span>
                        }
                        else
                        {
                            <span>🚀 Сгенерировать и открыть карту</span>
                        }
                    </button>
                </div>
                
            </div>
        </div>
    </form>
</section>

<style>
    .save-spinner {
        display: inline-block;
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        border-top-color: #fff;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

@code {
    private string goal = "";
    private string timeline = "";
    private string currentLevel = "Beginner";
    private string category = "Программирование";
    private bool isGenerating = false;

    private async Task HandleGenerateSubmit()
    {
        if (isGenerating) return;
        
        isGenerating = true;
        StateHasChanged();

        try
        {
            var generatedData = await Ai.GenerateRoadmapAsync(goal.Trim(), timeline.Trim(), currentLevel, category.Trim()); 
            
            if (generatedData == null)
            {
                await Js.InvokeVoidAsync("alert", "ИИ не смог построить карту. Попробуйте еще раз с более точной целью.");
                return;
            }

            // Задаем ID ментора (по умолчанию = 1)
            int userId = 1;

            var roadmapEntity = new RoadmapEntity 
            {
                OwnerUserId = userId, 
                Title = !string.IsNullOrWhiteSpace(generatedData.Title) ? generatedData.Title : goal.Trim(), 
                Description = !string.IsNullOrWhiteSpace(generatedData.Description) ? generatedData.Description : "Автоматически сгенерированный трек обучения.",
                Category = category.Trim(), 
                Difficulty = currentLevel, 
                CreatedAtUtc = DateTime.SpecifyKind(DateTime.UtcNow, DateTimeKind.Utc),
                UpdatedAtUtc = DateTime.SpecifyKind(DateTime.UtcNow, DateTimeKind.Utc),
                Tags = "ai-generated",
                CanvasData = "{}"
            };
            
            Db.Roadmaps.Add(roadmapEntity);
            await Db.SaveChangesAsync(); // Сохраняем карту, чтобы получить её верифицированный Id

            var idMap = new Dictionary<int, int>();
            var nodesList = generatedData.Nodes ?? new List<AiParsedNode>();
            
            for (int i = 0; i < nodesList.Count; i++)
            {
                var aiNode = nodesList[i];
                double level = i / 3; 
                double branch = i % 3;
                
                var node = new RoadmapNodeEntity 
                {
                    UserId = userId, 
                    RoadmapId = roadmapEntity.Id, 
                    Title = !string.IsNullOrWhiteSpace(aiNode.Title) ? aiNode.Title : $"Этап {i + 1}",
                    Description = !string.IsNullOrWhiteSpace(aiNode.Description) ? aiNode.Description : "Изучение концепций и инструментов темы.", 
                    Type = aiNode.Type ?? "Topic", 
                    Difficulty = aiNode.Difficulty ?? currentLevel,
                    Status = "Planned", 
                    Progress = 0,
                    PositionX = 100 + (branch * 320), 
                    PositionY = 120 + (level * 200),
                    Resource = "",
                    Tags = "ai"
                };
                
                Db.Nodes.Add(node);
                await Db.SaveChangesAsync(); // База генерирует уникальный Id для Postgres
                
                // Безопасно связываем исходный ИИ-идентификатор с реальным ключом базы данных
                idMap[aiNode.Id] = node.Id;
                
                if (aiNode.Materials != null)
                {
                    foreach (var m in aiNode.Materials)
                    {
                        if (string.IsNullOrEmpty(m.Url)) continue;
                        
                        Db.Materials.Add(new NodeMaterialEntity 
                        {
                            UserId = userId, 
                            RoadmapId = roadmapEntity.Id, 
                            NodeId = node.Id,
                            Title = !string.IsNullOrWhiteSpace(m.Title) ? m.Title : "Учебный ресурс", 
                            Description = m.Description ?? "", 
                            MaterialType = m.MaterialType ?? "Article", 
                            Url = m.Url
                        });
                    }
                }
            }
            
            if (generatedData.Edges != null)
            {
                foreach (var aiEdge in generatedData.Edges)
                {
                    // ИСПРАВЛЕНО: Безопасное извлечение ключей через TryGetValue исключает вылет по ошибке
                    if (idMap.TryGetValue(aiEdge.FromId, out int realFromId) && idMap.TryGetValue(aiEdge.ToId, out int realToId))
                    {
                        Db.Edges.Add(new RoadmapEdgeEntity 
                        {
                            UserId = userId, 
                            RoadmapId = roadmapEntity.Id,
                            FromNodeId = realFromId, 
                            ToNodeId = realToId,
                            EdgeType = "Solid", 
                            Thickness = 2, 
                            Color = "#6078a8"
                        });
                    }
                }
            }
            
            await Db.SaveChangesAsync(); // Финальное сохранение связей
            
            // Мгновенный переход на созданный холст
            Nav.NavigateTo($"/canvas/{roadmapEntity.Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[CRITICAL AI GENERATION FAIL]: {ex.Message} \n {ex.StackTrace}");
            await Js.InvokeVoidAsync("alert", "Ошибка при обработке и сохранении графа в базу данных.");
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }
}