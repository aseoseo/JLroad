@page "/ai-generator"
@layout WorkspaceLayout
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Text.Json.Serialization
@inject IJSRuntime Js
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory

<PageTitle>ИИ Генератор треков | JIroad</PageTitle>

<section class="panel page-enter px-2 px-md-3">
    <div style="margin-bottom: 1.5rem;">
        <h2 style="display: flex; align-items: center; gap: 0.5rem; margin: 0; flex-wrap: wrap;">🤖 Генерация дорожной карты через ИИ</h2>
        <p class="fine" style="margin-top: 0.35rem;">Укажите желаемую цель, и нейросеть автоматически спроектирует оптимальные этапы обучения, связи между ними и подберет полезные материалы.</p>
    </div>

    <form @onsubmit="HandleGenerateSubmit" @onsubmit:preventDefault="true">
        <div class="editor container-fluid m-0" style="max-width: 650px; background: #ffffff; padding: 1.5rem; border: 1px solid #e2e8f0; border-radius: 12px;">
            <div class="row g-3">
                
                <div class="col-12">
                    <label style="font-weight: 700; font-size: 0.9rem; color: #1e293b;">🎯 Какую технологию или профессию хотите освоить?</label>
                    <input type="text" style="width: 100%; margin-top: 0.4rem; box-sizing: border-box;" 
                           @bind="goal" 
                           placeholder="Например: Изучить C# и ASP.NET Core до уровня Junior" 
                           disabled="@isGenerating" required />
                </div>

                <div class="col-12">
                    <label style="font-weight: 700; font-size: 0.9rem; color: #1e293b;">⏱️ Сколько времени вы готовы выделить (Таймлайн)?</label>
                    <input type="text" style="width: 100%; margin-top: 0.4rem; box-sizing: border-box;" 
                           @bind="timeline" 
                           placeholder="Например: 2 месяца, по 15 часов в неделю" 
                           disabled="@isGenerating" required />
                </div>

                <div class="col-12 col-md-6">
                    <label style="font-weight: 700; font-size: 0.9rem; color: #1e293b;">📊 Текущий уровень:</label>
                    <select style="width: 100%; margin-top: 0.4rem; box-sizing: border-box; height: 38px;" @bind="currentLevel" disabled="@isGenerating">
                        <option value="Beginner">Новичок (Beginner)</option>
                        <option value="Intermediate">Средний (Intermediate)</option>
                        <option value="Advanced">Продвинутый (Advanced)</option>
                    </select>
                </div>

                <div class="col-12 col-md-6">
                    <label style="font-weight: 700; font-size: 0.9rem; color: #1e293b;">📂 Общая категория:</label>
                    <input type="text" style="width: 100%; margin-top: 0.4rem; box-sizing: border-box;" 
                           @bind="category" 
                           placeholder="Например: Программирование" 
                           disabled="@isGenerating" required />
                </div>

                <div class="col-12 pt-2">
                    <button type="submit" class="cta start-btn" style="width: 100%; justify-content: center; height: 46px; font-weight: 700;" disabled="@isGenerating">
                        @if (isGenerating)
                        {
                            <span class="save-spinner" style="margin-right: 8px;"></span>
                            <span>🧠 ИИ строит граф связей... Подождите</span>
                        }
                        else
                        {
                            <span>🚀 Сгенерировать и открыть карту</span>
                        }
                    </button>
                </div>
                
            </div>
        </div>
    </form>
</section>

<style>
    .save-spinner {
        display: inline-block;
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        border-top-color: #fff;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

@code {
    private string goal = "";
    private string timeline = "";
    private string currentLevel = "Beginner";
    private string category = "Программирование";
    private bool isGenerating = false;

    private async Task HandleGenerateSubmit()
    {
        if (isGenerating) return;
        
        isGenerating = true;
        StateHasChanged();

        try
        {
            var token = await Js.InvokeAsync<string>("jiroad.loadToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                Nav.NavigateTo("/auth/login");
                return;
            }

            // ИСПОЛЬЗУЕМ СТАНДАРТНЫЙ КЛИЕНТ: Nav.BaseUri всегда корректен для внешних запросов
            // фабрика избавит бэкенд от проблем с внутренними Docker портами
            var http = HttpClientFactory.CreateClient();
            http.BaseAddress = new Uri(Nav.BaseUri);
            http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            var payload = new
            {
                Goal = goal.Trim(),
                Timeline = timeline.Trim(),
                CurrentLevel = currentLevel,
                Category = category.Trim()
            };

            var response = await http.PostAsJsonAsync("api/roadmap/ai/generate", payload);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AiGenerationResult>();
                
                if (result != null && result.RoadmapId > 0)
                {
                    Nav.NavigateTo($"/canvas/{result.RoadmapId}");
                }
                else
                {
                    await Js.InvokeVoidAsync("alert", "Ошибка: Сервер успешно обработал запрос, но не вернул ID дорожной карты.");
                }
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"[AI Generation Failed]: {errorMsg}");
                await Js.InvokeVoidAsync("alert", "ИИ не смог распознать запрос или превышена квота. Измените формулировку цели.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AI Client Error]: {ex.Message}");
            await Js.InvokeVoidAsync("alert", "Ошибка соединения с сервером при генерации трека.");
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    private sealed class AiGenerationResult
    {
        [JsonPropertyName("roadmapId")]
        public int RoadmapId { get; set; }
    }
}